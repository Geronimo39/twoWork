# Option 2 – QACGJRN Job Accounting Journal

**Idee:** Wenn auf dem AS/400 **Job-Accounting** aktiviert ist, schreibt das System für jeden beendeten Job einen Journal-Eintrag in `QSYS/QACGJRN`.  
Diese Einträge enthalten sauber strukturierte Felder: Job-Name, User, Start- und Endzeit, CPU-Zeit usw.

**Voraussetzungen:** Job-Accounting muss aktiviert sein (`QACGLVL` Systemwert ≠ `*NONE`).  
Wir prüfen das im ersten Schritt.
import pyodbc
import pandas as pd

DSN        = 'AS400_DSN'   # <-- ggf. anpassen
MY_SCHEMA  = 'STEFAN'
JOB_FILTER = '%TAGEND_NOP%'

conn = pyodbc.connect(f'DSN={DSN}', autocommit=True)
conn.set_attr(pyodbc.SQL_ATTR_TXN_ISOLATION, 0)
print('Verbindung OK')
# ── Schritt 1: Ist Job-Accounting überhaupt aktiv? ───────────────────────────
# Systemwert QACGLVL steuert, was aufgezeichnet wird.
# *NONE = aus, *JOB = Basis-Accounting, *JOBDTA = erweitert

df_sysval = pd.read_sql(
    "SELECT * FROM QSYS2.SYSTEM_VALUE_INFO WHERE SYSTEM_VALUE_NAME = 'QACGLVL'",
    conn
)
print('QACGLVL:')
df_sysval
# ── Schritt 2: Journal-Receiver für QACGJRN ermitteln ────────────────────────
# DSPJRN dumpt Journal-Einträge in eine Outfile.
# Zuerst schauen, welcher Receiver aktuell angehängt ist.

cmd_dspjrn_info = "DSPJRN JRN(QSYS/QACGJRN) OUTPUT(*OUTFILE) OUTFILE(STEFAN/QACG_OUT) OUTMBR(*FIRST *REPLACE) ENTDTALEN(*VARLEN 1024)"

try:
    conn.execute(
        f"CALL QSYS2.QCMDEXC('{cmd_dspjrn_info}', {len(cmd_dspjrn_info):.5f})"
    )
    print('DSPJRN erfolgreich → STEFAN.QACG_OUT')
except Exception as e:
    print(f'FEHLER (Job-Accounting evtl. nicht aktiv): {e}')
# ── Schritt 3: Struktur der Outfile prüfen ───────────────────────────────────
df_cols = pd.read_sql(
    """
    SELECT COLUMN_NAME, DATA_TYPE, LENGTH
    FROM QSYS2.SYSCOLUMNS
    WHERE TABLE_SCHEMA = 'STEFAN' AND TABLE_NAME = 'QACG_OUT'
    """,
    conn
)
df_cols
# ── Schritt 4: Erste Rohdaten ansehen ────────────────────────────────────────
df_raw = pd.read_sql("SELECT * FROM STEFAN.QACG_OUT FETCH FIRST 10 ROWS ONLY", conn)
df_raw
# ── Schritt 5: Nach TAGEND_NOP filtern ───────────────────────────────────────
# Relevante Felder im QACGJRN-Outfile:
# JOBJOB = Job-Name, JOBUSER = User, JOBNBR = Job-Nummer
# JOBSDT / JOBEDT = Start/End-Datum (YYMMDD), JOBSTM / JOBEDT = Zeit
# (Feldnamen können je nach OS-Version leicht variieren – Schritt 4 zeigt die echten Namen)

df_jobs = pd.read_sql(
    f"""
    SELECT *
    FROM STEFAN.QACG_OUT
    WHERE JOBJOB LIKE '{JOB_FILTER}'
    ORDER BY JOBEDT DESC, JOBBDT DESC
    """,
    conn
)
print(f"{len(df_jobs)} Treffer")
df_jobs
# ── Hinweis: Falls Feldnamen anders lauten ───────────────────────────────────
# Falls der Filter oben fehlschlägt, alle Spalten mit 'JOB' im Namen anzeigen

job_cols = [c for c in df_raw.columns if 'JOB' in c.upper()]
print('Spalten mit JOB im Namen:', job_cols)

if job_cols:
    print('\nErste Werte:')
    print(df_raw[job_cols].head(5))
conn.close()
print('Fertig.')
