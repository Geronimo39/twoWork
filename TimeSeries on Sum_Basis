    plt.plot(temp["week"], temp["rolling_8w_mean"], label="Rolling 8W")
    plt.title(f"Trendglättung – {grp}")
    plt.xlabel("Woche")
    plt.ylabel("Absatz")
    plt.legend()
    plt.grid(True, alpha=0.3)
