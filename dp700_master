  <div class="section">
    <div class="section-title">Master-Glossar — alle Kernbegriffe beider Kurse</div>
    <div class="grid-2">
      <table>
        <tr><th>Begriff</th><th>Definition</th></tr>
        <tr><td><strong>OneLake</strong></td><td>Einziger Data Lake pro Fabric-Tenant — Fundament aller 5 Engines</td></tr>
        <tr><td><strong>Lakehouse</strong></td><td>OneLake + Delta Lake + SQL Endpoint — Warehouse mit Superkräften</td></tr>
        <tr><td><strong>Delta Lake</strong></td><td>Parquet + Transaction Log = ACID + Time Travel + Schema Evolution</td></tr>
        <tr><td><strong>Medallion</strong></td><td>Bronze (roh) → Silver (bereinigt) → Gold (business-ready)</td></tr>
        <tr><td><strong>SHIR</strong></td><td>Self-hosted Integration Runtime — Brücke zu Legacy-Quellen (Port 443 ausgehend)</td></tr>
        <tr><td><strong>Shortcut</strong></td><td>Virtueller Zeiger auf ADLS — kein Datenmove, Delegated Access beachten!</td></tr>
        <tr><td><strong>DirectLake</strong></td><td>Power BI liest Delta direkt — schnell UND aktuell, nur in Fabric</td></tr>
        <tr><td><strong>Semantic Model</strong></td><td>Abstraktionsschicht zwischen Daten und Report — einzige Wahrheit</td></tr>
        <tr><td><strong>MERGE/UPSERT</strong></td><td>PK-Vergleich: Update bei Treffer, Insert bei Neu — idempotent</td></tr>
        <tr><td><strong>Idempotenz</strong></td><td>Mehrfaches Ausführen = immer dasselbe Ergebnis</td></tr>
        <tr><td><strong>Lazy Evaluation</strong></td><td>Spark-Transformationen erst bei Action ausgeführt</td></tr>
        <tr><td><strong>OPTIMIZE</strong></td><td>Delta: kleine Dateien kompaktieren → Leseperformance</td></tr>
        <tr><td><strong>VACUUM</strong></td><td>Delta: alte Dateien löschen → beeinflusst Time Travel</td></tr>
        <tr><td><strong>Z-ORDER</strong></td><td>Physisches Clustering → Filterabfragen schneller</td></tr>
        <tr><td><strong>V-Order</strong></td><td>Microsofts Parquet-Erweiterung → schnellere DirectLake-Reads</td></tr>
      </table>
      <table>
        <tr><th>Begriff</th><th>Definition</th></tr>
        <tr><td><strong>KQL</strong></td><td>Kusto Query Language: pipe-basiert, read-only, Real-Time Intelligence</td></tr>
        <tr><td><strong>RLS dynamisch</strong></td><td>USERPRINCIPALNAME() — eine Rolle für alle Nutzer, skalierbar</td></tr>
        <tr><td><strong>OLS</strong></td><td>Object-Level Security: Tabellen/Spalten im Semantic Model verstecken</td></tr>
        <tr><td><strong>DDM</strong></td><td>Dynamic Data Masking: Spalten maskiert anzeigen (Warehouse)</td></tr>
        <tr><td><strong>Smoothing</strong></td><td>CU-Spitzen über 24h verteilen — schützt vor Throttling</td></tr>
