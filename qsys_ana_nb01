           ref_object AS called_pgm, ref_lib AS called_lib,
           ref_key AS called_key, ref_type AS call_type
    FROM dsppgmref_clean WHERE is_pgm_ref = 1
""",

"v_pgm_profile": """
    CREATE VIEW IF NOT EXISTS v_pgm_profile AS
    SELECT
        o.pgm_lib, o.pgm_name, o.pgm_key,
        o.pgm_attribute, o.pgm_text, o.owner,
        o.created_at, o.changed_at, o.last_used_at, o.obj_size,
        o.compiler_name,
        s.days_used_count,
        s.last_used_timestamp,
        s.creation_timestamp AS stat_created,
        COUNT(DISTINCT CASE WHEN r.is_file_ref=1 THEN r.ref_object END) AS total_file_refs,
        COUNT(DISTINCT CASE WHEN r.is_write=1    THEN r.ref_object END) AS tables_written,
        COUNT(DISTINCT CASE WHEN r.is_read=1     THEN r.ref_object END) AS tables_read,
        COUNT(DISTINCT CASE WHEN r.is_pgm_ref=1  THEN r.ref_object END) AS calls_out
    FROM dspobjd_clean o
    LEFT JOIN dsppgmref_clean r ON o.pgm_key = r.pgm_key
    LEFT JOIN sysprogramstat  s ON o.pgm_name = s.program_name
                                AND o.pgm_lib  = s.program_schema
    GROUP BY o.pgm_lib, o.pgm_name, o.pgm_key,
             o.pgm_attribute, o.pgm_text, o.owner,
             o.created_at, o.changed_at, o.last_used_at,
             o.obj_size, o.compiler_name,
             s.days_used_count, s.last_used_timestamp, s.creation_timestamp
""",

"v_table_profile": """
    CREATE VIEW IF NOT EXISTS v_table_profile AS
    SELECT
        a.table_lib, a.table_name, a.table_key,
        t.table_text,
        ts.number_rows, ts.number_deleted_rows,
        ts.days_used_count    AS tbl_days_used,
        ts.last_used_timestamp AS tbl_last_used,
        COUNT(DISTINCT a.pgm_key)                                  AS pgm_count,
        COUNT(DISTINCT CASE WHEN a.is_read=1  THEN a.pgm_key END)  AS reader_count,
        COUNT(DISTINCT CASE WHEN a.is_write=1 THEN a.pgm_key END)  AS writer_count,
        COUNT(DISTINCT CASE WHEN a.usage='D'  THEN a.pgm_key END)  AS deleter_count,
        COUNT(DISTINCT i.index_name)                               AS index_count
    FROM v_data_access a
    LEFT JOIN systables    t  ON a.table_name=t.table_name AND a.table_lib=t.table_schema
    LEFT JOIN systablestat ts ON a.table_name=ts.table_name AND a.table_lib=ts.table_schema
    LEFT JOIN sysindexes   i  ON a.table_name=i.table_name AND a.table_lib=i.table_schema
    GROUP BY a.table_lib, a.table_name, a.table_key,
             t.table_text, ts.number_rows, ts.number_deleted_rows,
             ts.days_used_count, ts.last_used_timestamp
""",

"v_trigger_overview": """
    CREATE VIEW IF NOT EXISTS v_trigger_overview AS
    SELECT
        event_object_schema AS table_lib,
        event_object_table  AS table_name,
        trigger_name, event_manipulation, action_timing,
        trigger_program_library AS pgm_lib,
        trigger_program_name    AS pgm_name,
        operative, enabled
    FROM systriggers
""",

"v_importance_score": """
    CREATE VIEW IF NOT EXISTS v_importance_score AS
    SELECT
        pgm_key, pgm_lib, pgm_name, pgm_attribute, pgm_text, owner,
        days_used_count, total_file_refs, tables_written, tables_read, calls_out,
        ROUND(
            (
                COALESCE(CAST(days_used_count AS FLOAT), 0) * 0.35 +
                COALESCE(CAST(tables_written  AS FLOAT), 0) * 0.30 +
                COALESCE(CAST(total_file_refs AS FLOAT), 0) * 0.20 +
                COALESCE(CAST(calls_out       AS FLOAT), 0) * 0.15
            ) / NULLIF((
                SELECT MAX(
                    COALESCE(CAST(days_used_count AS FLOAT),0)*0.35 +
                    COALESCE(CAST(tables_written  AS FLOAT),0)*0.30 +
                    COALESCE(CAST(total_file_refs AS FLOAT),0)*0.20 +
                    COALESCE(CAST(calls_out       AS FLOAT),0)*0.15
                ) FROM v_pgm_profile
            ), 0) * 100
        , 1) AS importance_score
    FROM v_pgm_profile
