# =============================================================================
# ── Hilfsfunktionen ───────────────────────────────────────────────────────────
# =============================================================================

def get_connection():
    return pyodbc.connect(f"DSN={ODBC_DSN}", autocommit=True)

def load_parquet(path: Path, label: str):
    if path is None or not path.exists():
        log.warning(f"{label}: nicht gefunden – übersprungen")
        return None
    df = pd.read_parquet(path)
    log.info(f"{label}: {len(df):,} Zeilen")
    return df

def drop_binary_cols(df: pd.DataFrame) -> pd.DataFrame:
    cols = [c for c in BINARY_COLS_TO_DROP if c in df.columns]
    if cols:
        log.info(f"  Droppe Binärspalten: {cols}")
        df = df.drop(columns=cols)
    return df

def trim_strings(df: pd.DataFrame) -> pd.DataFrame:
    for c in df.select_dtypes(include="object").columns:
        df[c] = df[c].str.strip()
    return df

def build_as400_date(df, century_col, date_col, new_col):
    if date_col not in df.columns:
        return df
    try:
        if century_col in df.columns:
            prefix = df[century_col].fillna(0).astype(int).map(
                {0: "19", 1: "20"}).fillna("19")
            full = prefix + df[date_col].astype(str).str.zfill(6)
        else:
            full = df[date_col].astype(str)
        df[new_col] = pd.to_datetime(full, format="%Y%m%d", errors="coerce")
    except Exception as e:
        log.warning(f"Datum {new_col}: {e}")
    return df

# =============================================================================
# ── Bereinigungs-Funktionen ───────────────────────────────────────────────────
# =============================================================================

def clean_objd(df_raw: pd.DataFrame) -> pd.DataFrame:
    df = drop_binary_cols(df_raw.copy())
    df = df.rename(columns={k: v for k, v in OBJD_RENAME.items() if k in df.columns})
    df = trim_strings(df)
    df = build_as400_date(df, "create_century",   "create_date",   "created_at")
    df = build_as400_date(df, "change_century",   "change_date",   "changed_at")
    df = build_as400_date(df, "last_use_century", "last_use_date", "last_used_at")
    if "pgm_name" in df.columns and "pgm_lib" in df.columns:
        df["pgm_key"] = df["pgm_lib"] + "." + df["pgm_name"]
    log.info(f"DSPOBJD clean: {len(df):,} Programme, "
             f"{df.get('pgm_lib', pd.Series()).nunique()} Libraries")
    return df

def clean_pgmref(df_raw: pd.DataFrame) -> pd.DataFrame:
    df = drop_binary_cols(df_raw.copy())
    df = df.rename(columns={k: v for k, v in PGMREF_RENAME.items() if k in df.columns})
    df = trim_strings(df)
    if "usage" in df.columns:
        df["usage_label"] = df["usage"].map(USAGE_MAP).fillna("UNKNOWN")
    if "pgm_name" in df.columns and "pgm_lib" in df.columns:
        df["pgm_key"] = df["pgm_lib"] + "." + df["pgm_name"]
    if "ref_object" in df.columns and "ref_lib" in df.columns:
        df["ref_key"] = df["ref_lib"] + "." + df["ref_object"]
    if "ref_type" in df.columns:
        df["is_file_ref"] = df["ref_type"].eq("*FILE").astype(int)
        df["is_pgm_ref"]  = df["ref_type"].isin(["*PGM", "*SRVPGM"]).astype(int)
    if "usage" in df.columns:
        df["is_write"] = df["usage"].isin(["O", "U", "D"]).astype(int)
        df["is_read"]  = df["usage"].eq("I").astype(int)
    log.info(f"DSPPGMREF clean: {len(df):,} Referenzen")
    return df

def fetch_qsys2(conn) -> dict:
    results = {}
    for name, sql in QSYS2_QUERIES.items():
        log.info(f"Abfrage QSYS2.{name.upper()} ...")
        try:
            df = pd.read_sql(sql, conn)
            df = drop_binary_cols(df)
            df = trim_strings(df)
            df.to_parquet(PARQUET_DIR / f"{name}_raw.parquet", index=False)
            log.info(f"  → {len(df):,} Zeilen")
            results[name] = df
        except Exception as e:
            log.warning(f"  {name} fehlgeschlagen: {e}")
            results[name] = None
        time.sleep(0.2)
    return results

