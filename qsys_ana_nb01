# =============================================================================
# ── SQLite befüllen ───────────────────────────────────────────────────────────
# =============================================================================

def build_sqlite(dfs: dict, db_path: Path):
    log.info(f"Baue SQLite: {db_path}")
    with sqlite3.connect(db_path) as db:
        for name, df in dfs.items():
            if df is not None and len(df) > 0:
                df.to_sql(name, db, if_exists="replace", index=False)
                log.info(f"  '{name}': {len(df):,} Zeilen")
        for vname, ddl in SQLITE_VIEWS.items():
            try:
                db.execute(f"DROP VIEW IF EXISTS {vname}")
                db.execute(ddl)
                log.info(f"  View '{vname}' ✓")
            except Exception as e:
                log.warning(f"  View '{vname}': {e}")
        db.commit()
    log.info("✓ SQLite fertig")

# =============================================================================
# ── Plausibilitäts-Check ──────────────────────────────────────────────────────
# =============================================================================

def plausibility_check(db_path: Path):
    print("\n" + "=" * 65)
    print("PLAUSIBILITÄTS-CHECK  –  as400_analysis.sqlite")
    print("=" * 65)
    with sqlite3.connect(db_path) as db:
        checks = {
            "Programme (DSPOBJD)":           "SELECT COUNT(*) FROM dspobjd_clean",
            "Referenzen (DSPPGMREF)":         "SELECT COUNT(*) FROM dsppgmref_clean",
            "Datei-Zugriffe":                 "SELECT COUNT(*) FROM v_data_access",
            "Call-Graph-Kanten":              "SELECT COUNT(*) FROM v_call_edges",
            "Unique referenzierte Tabellen":  "SELECT COUNT(DISTINCT table_key) FROM v_data_access",
            "Trigger":                        "SELECT COUNT(*) FROM systriggers",
            "SQL-Routinen":                   "SELECT COUNT(*) FROM sysroutines",
            "Indizes":                        "SELECT COUNT(*) FROM sysindexes",
            "Tabellen (SYSTABLES)":           "SELECT COUNT(*) FROM systables",
        }
        for label, sql in checks.items():
            try:
                n = db.execute(sql).fetchone()[0]
                print(f"  {label:<45} {n:>10,}")
            except Exception as e:
                print(f"  {label:<45} {'FEHLER':>10}  ({e})")

        print("\n── Top 10 Programme (Importance-Score) ─────────────────────")
        try:
            df = pd.read_sql("""
                SELECT pgm_lib, pgm_name, pgm_attribute,
                       importance_score, days_used_count,
                       tables_written, calls_out
                FROM v_importance_score LIMIT 10
            """, db)
            print(df.to_string(index=False))
        except Exception as e:
            print(f"  ({e})")

        print("\n── Top 10 meistgenutzte Tabellen ───────────────────────────")
        try:
            df = pd.read_sql("""
                SELECT table_lib, table_name, pgm_count,
                       reader_count, writer_count, number_rows
                FROM v_table_profile ORDER BY pgm_count DESC LIMIT 10
            """, db)
            print(df.to_string(index=False))
        except Exception as e:
            print(f"  ({e})")
    print("=" * 65)

# =============================================================================
# ── Hauptlauf ─────────────────────────────────────────────────────────────────
# =============================================================================

def main():
    log.info("nb_01_extract.py – Start")

    df_objd_raw   = load_parquet(DSPOBJD_PARQUET,   "DSPOBJD")
    df_pgmref_raw = load_parquet(DSPPGMREF_PARQUET, "DSPPGMREF")
    if df_objd_raw is None or df_pgmref_raw is None:
        log.error("DSPOBJD oder DSPPGMREF fehlen – Abbruch.")
        return

    df_objd_clean   = clean_objd(df_objd_raw)
    df_pgmref_clean = clean_pgmref(df_pgmref_raw)
    df_objd_clean.to_parquet(PARQUET_DIR / "dspobjd_clean.parquet",    index=False)
    df_pgmref_clean.to_parquet(PARQUET_DIR / "dsppgmref_clean.parquet", index=False)

    if PYODBC_AVAILABLE:
        conn = get_connection()
        qsys2_dfs = fetch_qsys2(conn)
        conn.close()
    else:
        log.warning("pyodbc nicht verfügbar – lade QSYS2-Parquets falls vorhanden")
        qsys2_dfs = {
            name: load_parquet(PARQUET_DIR / f"{name}_raw.parquet", name)
            for name in QSYS2_QUERIES
        }

    all_dfs = {
        "dspobjd_raw":     df_objd_raw,
        "dspobjd_clean":   df_objd_clean,
        "dsppgmref_raw":   df_pgmref_raw,
        "dsppgmref_clean": df_pgmref_clean,
    }
    all_dfs.update({k: v for k, v in qsys2_dfs.items() if v is not None})

    for label, path in [
        ("phase1_core_tables", PHASE1_PARQUET),
        ("rpg_source",         RPG_SOURCE_PARQUET),
        ("cl_source",          CL_SOURCE_PARQUET),
    ]:
        df = load_parquet(path, label)
        if df is not None:
            all_dfs[label] = df

    build_sqlite(all_dfs, SQLITE_DB)
    plausibility_check(SQLITE_DB)
    log.info("✓ nb_01_extract.py abgeschlossen")

if __name__ == "__main__":
    main()
