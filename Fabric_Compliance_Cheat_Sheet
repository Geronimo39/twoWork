<!-- SEITE 2: Purview, Databricks Unity Catalog, Monitoring -->
<div class="page">
  <div class="page-header">
    <div><h1>MS Fabric — Cheat-Sheet Woche 5</h1><div class="subtitle">Microsoft Purview · Databricks Unity Catalog · Monitoring &amp; Alerting</div></div>
