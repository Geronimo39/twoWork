    <table>
      <tr><th style="width:18%">Rolle</th><th style="width:12%">Lesen</th><th style="width:14%">Bearbeiten</th><th style="width:14%">Publizieren</th><th style="width:14%">Verwalten</th><th style="width:28%">dispDB-Zuweisung</th></tr>
      <tr><td><strong>Viewer</strong></td><td>✓</td><td>✗</td><td>✗</td><td>✗</td><td>Vorstand, Business-Nutzer (nur Reports lesen)</td></tr>
      <tr><td><strong>Contributor</strong></td><td>✓</td><td>✓</td><td>✗</td><td>✗</td><td>Data Analyst (Entwicklung, kein Publish)</td></tr>
      <tr><td><strong>Member</strong></td><td>✓</td><td>✓</td><td>✓</td><td>teilweise</td><td>Data Scientist, IT-Infrastruktur-Kollege</td></tr>
