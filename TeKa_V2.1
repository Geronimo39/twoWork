Option Explicit

' Optionales Schutzpasswort.
' Leer lassen = Blattschutz ohne Passwort.
' Hinweis: Ein Passwort im VBA-Code ist kein echter Sicherheitsschutz,
' sondern nur ein Bearbeitungsschutz.
Private KALENDER_SCHUTZ_PASSWORT As String

' Vertraglicher monatlicher Urlaubsanspruch je aktivem Mitarbeiter-Monat.
' Standard: 2,5 Tage pro aktivem Monat.
' Sonderfälle, z. B. Eintritt mitten im Monat, können bei Bedarf
' in der ausgeblendeten Hilfsspalte AO manuell angepasst werden.
Private Const VERTRGL_URLAUB As Double = 2.5





' ============================================================
' Modul: modKalenderDynamisch
'
' Zweck:
'   Dynamischer Aufbau der Monatsblöcke im Kalenderblatt
'   inklusive Mitarbeiterlogik, Spezialformatierung,
'   Dropdowns, Status-Farbregeln, Statusformeln,
'   Statistik, Statuscode-Legende und Zellschutz.
'
' Version 2.0 - Arbeitsstand 1:
'   - Abteilungen werden hart im VBA-Code geführt.
'   - IT-Security wurde zu IT-Compliance geändert.
'   - Business-Transformation wurde zu Business Transformation geändert.
'   - Statusfarben werden hart über StatusFarbDictionary geführt.
'   - tblStatus wird für Farben und Dropdowns nicht mehr benötigt.
'   - StatusDropdownCodes wird aus einer sichtbaren Legende im Kalenderblatt erzeugt.
'   - Dropdowns beziehen sich auf diese sichtbare Statuscode-Legende.
'   - Nicht verwendete Tagesspalten bei Monaten mit weniger als 31 Tagen
'     werden ohne störende innere Linien dargestellt.
'   - URLAUB_PRO_AKTIVEM_MONAT wurde zu VERTRGL_URLAUB umbenannt.
'
' Voraussetzungen:
'   - Aktives Blatt beginnt mit "Kalender", z. B. "Kalender" oder "Kalender_2026"
'   - In H1 steht ein echtes Datum, z. B. 01.01.2026
'   - Blatt "Mitarbeiter" existiert
'   - Blatt "Parameter" existiert noch für tblMapping, tblFeiertage, tblFerien
'   - Benannter Bereich "tblMapping" existiert
'     mit SpeicherCode / AnzeigeCode
'   - Tabelle "tblFeiertage" existiert im Blatt "Parameter"
'   - Tabelle "tblFerien" existiert im Blatt "Parameter"
'
' Nicht mehr benötigt:
'   - tblStatus
'   - StatusAnzeigeCodes
'   - Abteilungen im Parameterblatt
'
' Mitarbeiterblatt:
'       A: Key
'       B: Name
'       C: Vorname
'       D: Anzeigename
'       E: Abteilung
'       F: Startdatum
'       G: Enddatum
'       H: Urlaubstage
'       I: Bemerkung
'
' Kalender:
'       D:AH = Tagesbereich
'
' Statistik sichtbar:
'       X  = IST
'       Y  = Soll
'       Z  = offen
'       AA = Abteilung / Mitarbeiter
'       AE = MW
'       AF = K
'       AG = Sonst
'       AH = Büro
'
' Statistik-Hilfsspalten:
'       AJ = Urlaub IST
'       AK = MW
'       AL = K
'       AM = Sonstiges
'       AN = Büro
'       AO = Urlaub Soll
' ============================================================


' ============================================================
' Hart definierte Abteilungen
'
' Diese Reihenfolge bestimmt:
'   - Reihenfolge der Abteilungsblöcke in den Monatsblöcken
'   - Reihenfolge der Abteilungen in der Jahresstatistik
'
' Wichtig:
'   Die Werte müssen mit Spalte E im Mitarbeiterblatt
'   exakt übereinstimmen.
' ============================================================

Private Function KalenderAbteilungen() As Variant

    KalenderAbteilungen = Array( _
        "IT-Operations", _
        "IT-Compliance", _
        "Business Transformation" _
    )

End Function


' ============================================================
' Feste Farbzuordnung für Statuscodes
'
' Hinweis:
'   VBA erlaubt keine direkt initialisierten Const-Dictionaries.
'   Daher wird die feste Farbzuordnung einmalig als Static Dictionary
'   aufgebaut und anschließend wiederverwendet.
'
' Grundlage:
'   Key   = AnzeigeCode im Kalender
'   Value = RGB-Farbwert
' ============================================================

Private Function StatusFarbDictionary() As Object

    Static dict As Object

    If dict Is Nothing Then

        Set dict = CreateObject("Scripting.Dictionary")

        ' Dienste
        dict.Add "FD", RGB(146, 208, 80)        ' grün
        dict.Add "FD/MW", RGB(146, 208, 80)     ' grün

        dict.Add "SD", RGB(201, 85, 21)         ' braun
        dict.Add "SD/MW", RGB(201, 85, 21)      ' braun

        ' Mobile Work
        dict.Add "MW", RGB(255, 255, 0)         ' gelb

        ' Sonderzeiten / Abwesenheiten
        dict.Add "17h", RGB(217, 217, 217)      ' grau

        dict.Add "UT", RGB(192, 230, 245)       ' hellblau
        dict.Add "UT5", RGB(192, 230, 245)      ' hellblau
        dict.Add "SU", RGB(192, 230, 245)       ' hellblau

        dict.Add "GT", RGB(228, 158, 221)       ' lila
        dict.Add "GT5", RGB(228, 158, 221)      ' lila

        dict.Add "K", RGB(255, 199, 206)        ' rot
        dict.Add "Schu", RGB(126, 53, 14)       ' dunkelbraun
        dict.Add "DR", RGB(255, 192, 0)         ' orange
        dict.Add "SAD", RGB(77, 147, 217)       ' blau

        ' Sonstiges / neutral
        dict.Add "--", RGB(255, 255, 255)       ' weiß

    End If

    Set StatusFarbDictionary = dict

End Function


