' ============================================================
' Formatierungs-Spezial
' ============================================================

Private Sub FormatiereMonatsblockSpezial( _
    ByVal wsKal As Worksheet, _
    ByVal blockStartRow As Long, _
    ByVal blockEndRow As Long, _
    ByVal firstDayCol As Long, _
    ByVal lastDayCol As Long, _
    ByVal opsCount As Long, _
    ByVal secCount As Long, _
    ByVal busCount As Long)

    Dim weekdayRow As Long
    Dim opsStartRow As Long
    Dim opsEndRow As Long
    Dim blankAfterOpsRow As Long
    Dim secStartRow As Long
    Dim secEndRow As Long
    Dim blankAfterSecRow As Long
    Dim statusStartRow As Long
    Dim statusEndRow As Long
    Dim blankAfterStatusRow As Long
    Dim busStartRow As Long
    Dim busEndRow As Long
    Dim kwRow As Long

    ' Zeilenpositionen innerhalb des Monatsblocks berechnen
    weekdayRow = blockStartRow

    opsStartRow = weekdayRow + 1
    opsEndRow = opsStartRow + opsCount - 1
    blankAfterOpsRow = opsEndRow + 1

    secStartRow = blankAfterOpsRow + 1
    secEndRow = secStartRow + secCount - 1
    blankAfterSecRow = secEndRow + 1

    statusStartRow = blankAfterSecRow + 1
    statusEndRow = statusStartRow + 1
    blankAfterStatusRow = statusEndRow + 1

    busStartRow = blankAfterStatusRow + 1
    busEndRow = busStartRow + busCount - 1

    kwRow = blockEndRow

    ' 1. Wochentagszeile ohne vertikale Zwischenstriche
    With wsKal.Range(wsKal.Cells(weekdayRow, firstDayCol - 2), wsKal.Cells(weekdayRow, lastDayCol))
        .Borders(xlInsideVertical).LineStyle = xlNone
    End With

    ' 2. Kalenderwochenzeile ohne vertikale Zwischenstriche
    With wsKal.Range(wsKal.Cells(kwRow, firstDayCol - 2), wsKal.Cells(kwRow, lastDayCol))
        .Borders(xlInsideVertical).LineStyle = xlNone
    End With

    ' 3. Leerzeilen ohne vertikale Zwischenstriche
    Call EntferneVertikaleInnenlinienInZeile(wsKal, blankAfterOpsRow, firstDayCol - 2, lastDayCol)
    Call EntferneVertikaleInnenlinienInZeile(wsKal, blankAfterSecRow, firstDayCol - 2, lastDayCol)
    Call EntferneVertikaleInnenlinienInZeile(wsKal, blankAfterStatusRow, firstDayCol - 2, lastDayCol)

    ' 4. Abteilungsspalte B innerhalb der Abteilungsblöcke
    '    ohne horizontale Zwischenstriche
    If opsCount > 1 Then
        wsKal.Range(wsKal.Cells(opsStartRow, 2), wsKal.Cells(opsEndRow, 2)) _
             .Borders(xlInsideHorizontal).LineStyle = xlNone
    End If

    If secCount > 1 Then
        wsKal.Range(wsKal.Cells(secStartRow, 2), wsKal.Cells(secEndRow, 2)) _
             .Borders(xlInsideHorizontal).LineStyle = xlNone
    End If

    If busCount > 1 Then
        wsKal.Range(wsKal.Cells(busStartRow, 2), wsKal.Cells(busEndRow, 2)) _
             .Borders(xlInsideHorizontal).LineStyle = xlNone
    End If

    ' 5. Status-/Zwischenbereich in Spalte B:
    '    Keine horizontalen Linien zwischen IT-Compliance und
    '    Business Transformation.
    With wsKal.Range(wsKal.Cells(blankAfterSecRow, 2), wsKal.Cells(blankAfterStatusRow, 2))
        .Borders(xlInsideHorizontal).LineStyle = xlNone
    End With

End Sub


' ============================================================
' Vertikale Innenlinien in einer Zeile entfernen
' ============================================================

Private Sub EntferneVertikaleInnenlinienInZeile( _
    ByVal wsKal As Worksheet, _
    ByVal targetRow As Long, _
    ByVal firstDayCol As Long, _
    ByVal lastDayCol As Long)

    With wsKal.Range(wsKal.Cells(targetRow, firstDayCol), wsKal.Cells(targetRow, lastDayCol))
        .Borders(xlInsideVertical).LineStyle = xlNone
    End With

End Sub


' ============================================================
' Nicht verwendete Tagesspalten optisch beruhigen
'
' Bei Monaten mit weniger als 31 Tagen werden die restlichen
' Tagesspalten zwar benötigt, damit die Monatsblöcke gleich breit
' bleiben, sie sollen aber keine störenden inneren Linien zeigen.
'
' Wirkung:
'   - Inhalte bleiben leer
'   - Datenüberprüfung wird entfernt
'   - Füllung wird entfernt
'   - innere Linien werden entfernt
'   - rechter Außenrahmen des Monatsblocks bleibt erhalten
'   - oberer und unterer Außenrahmen bleiben erhalten
' ============================================================

Private Sub FormatiereNichtVerwendeteTagesspalten( _
    ByVal wsKal As Worksheet, _
    ByVal blockStartRow As Long, _
    ByVal blockEndRow As Long, _
    ByVal firstDayCol As Long, _
    ByVal lastDayCol As Long, _
    ByVal daysInMonth As Long)

    Dim firstUnusedCol As Long
    Dim rngUnused As Range

    If daysInMonth >= 31 Then Exit Sub

    firstUnusedCol = firstDayCol + daysInMonth

    Set rngUnused = wsKal.Range(wsKal.Cells(blockStartRow, firstUnusedCol), _
                                wsKal.Cells(blockEndRow, lastDayCol))

    With rngUnused
        .ClearContents

        On Error Resume Next
        .Validation.Delete
        On Error GoTo 0

        .Interior.Pattern = xlNone
        .Borders.LineStyle = xlNone
    End With

    ' Rechten Außenrahmen des Monatsblocks wiederherstellen
    With wsKal.Range(wsKal.Cells(blockStartRow, lastDayCol), _
                     wsKal.Cells(blockEndRow, lastDayCol)).Borders(xlEdgeRight)
        .LineStyle = xlContinuous
        .Weight = xlThick
    End With

    ' Oberen Außenrahmen im ungenutzten Bereich wiederherstellen
    With wsKal.Range(wsKal.Cells(blockStartRow, firstUnusedCol), _
                     wsKal.Cells(blockStartRow, lastDayCol)).Borders(xlEdgeTop)
        .LineStyle = xlContinuous
        .Weight = xlThick
    End With

    ' Unteren Außenrahmen im ungenutzten Bereich wiederherstellen
    With wsKal.Range(wsKal.Cells(blockEndRow, firstUnusedCol), _
                     wsKal.Cells(blockEndRow, lastDayCol)).Borders(xlEdgeBottom)
        .LineStyle = xlContinuous
        .Weight = xlThick
    End With

End Sub


' ============================================================
' Wochenenden im Monatsblock einfärben
'
' Samstag: RGB(255, 255, 204)
' Sonntag: RGB(255, 204, 0)
'
' Es wird jeweils die komplette Tagesspalte innerhalb
' des Monatsblocks eingefärbt.
' ============================================================

Private Sub FaerbeWochenendenMonatsblock( _
    ByVal wsKal As Worksheet, _
    ByVal jahr As Long, _
    ByVal monat As Long, _
    ByVal blockStartRow As Long, _
    ByVal blockEndRow As Long, _
    ByVal firstDayCol As Long, _
    ByVal daysInMonth As Long)

    Dim tag As Long
    Dim d As Date
    Dim col As Long
    Dim rngTagesspalte As Range

    For tag = 1 To daysInMonth

        d = DateSerial(jahr, monat, tag)
        col = firstDayCol + tag - 1

        Set rngTagesspalte = wsKal.Range(wsKal.Cells(blockStartRow, col), _
                                         wsKal.Cells(blockEndRow, col))

        Select Case Weekday(d, vbMonday)

            Case 6
                ' Samstag
                rngTagesspalte.Interior.Color = RGB(255, 255, 204)

            Case 7
                ' Sonntag
                rngTagesspalte.Interior.Color = RGB(255, 204, 0)

        End Select

    Next tag

End Sub


' ============================================================
' Feiertage im Monatsblock markieren
'
' Quelle:
'   Blatt "Parameter"
'   Tabelle "tblFeiertage"
'   Spalten:
'       Feiertag
'       Abkuerzung oder Abkürzung
'       Datum
'
' Wirkung:
'   - Feiertage werden nur markiert, wenn sie auf Mo-Fr fallen
'   - Feiertagsspalte wird bis zur letzten Abteilungszeile gefärbt
'   - Wochentag in der Kopfzeile wird durch Feiertags-Abkürzung ersetzt
'   - Kalenderwochenzeile bleibt ungefärbt
' ============================================================

Private Sub MarkiereFeiertageMonatsblock( _
    ByVal wsKal As Worksheet, _
    ByVal jahr As Long, _
    ByVal monat As Long, _
    ByVal blockStartRow As Long, _
    ByVal firstDayCol As Long, _
    ByVal busStartRow As Long, _
    ByVal busCount As Long)

    Dim wsParam As Worksheet
    Dim tbl As ListObject

    Dim datumCol As Long
    Dim abkCol As Long

    Dim i As Long
    Dim feiertagsDatum As Date
    Dim abkuerzung As String

    Dim col As Long
    Dim letzteAbteilungsZeile As Long
    Dim rngFeiertag As Range

    If busCount <= 0 Then Exit Sub

    letzteAbteilungsZeile = busStartRow + busCount - 1

    Set wsParam = ThisWorkbook.Worksheets("Parameter")
    Set tbl = wsParam.ListObjects("tblFeiertage")

    datumCol = tbl.ListColumns("Datum").Index
    abkCol = HoleTabellenspaltenIndex(tbl, "Abkuerzung")

    If abkCol = 0 Then
        abkCol = HoleTabellenspaltenIndex(tbl, "Abkürzung")
    End If

    If abkCol = 0 Then
        MsgBox "In tblFeiertage fehlt die Spalte 'Abkuerzung' bzw. 'Abkürzung'.", vbExclamation
        Exit Sub
    End If

    For i = 1 To tbl.DataBodyRange.Rows.count

        If IsDate(tbl.DataBodyRange.Cells(i, datumCol).Value) Then

            feiertagsDatum = CDate(tbl.DataBodyRange.Cells(i, datumCol).Value)

            If Year(feiertagsDatum) = jahr And Month(feiertagsDatum) = monat Then

                ' Feiertage nur markieren, wenn sie auf Montag bis Freitag fallen
                If Weekday(feiertagsDatum, vbMonday) <= 5 Then

                    abkuerzung = Trim(CStr(tbl.DataBodyRange.Cells(i, abkCol).Value))
                    col = firstDayCol + Day(feiertagsDatum) - 1

                    ' Feiertagsspalte nur bis zur letzten Abteilungszeile einfärben
                    Set rngFeiertag = wsKal.Range(wsKal.Cells(blockStartRow, col), _
                                                  wsKal.Cells(letzteAbteilungsZeile, col))

                    rngFeiertag.Interior.Color = RGB(255, 193, 193)

                    ' In der Wochentagszeile die Abkürzung setzen
                    With wsKal.Cells(blockStartRow, col)
                        .Value = abkuerzung
                        .Font.Color = RGB(192, 0, 0)
                        .Font.Bold = False
                        .HorizontalAlignment = xlCenter
                        .VerticalAlignment = xlCenter
                    End With

                End If

            End If

        End If

    Next i

End Sub


' ============================================================
' Status-Farbregeln global für den Kalenderbereich setzen
'
' Version 2.0:
'   Die Statuscodes und Farben werden nicht mehr aus tblStatus
'   im Parameterblatt gelesen, sondern vollständig aus dem
'   modulweiten StatusFarbDictionary erzeugt.
' ============================================================

Private Sub SetzeStatusFarbregelnKalenderbereich( _
    ByVal wsKal As Worksheet, _
    ByVal firstRow As Long, _
    ByVal lastRow As Long, _
    ByVal firstDayCol As Long, _
    ByVal lastDayCol As Long)

    Dim rngZiel As Range
    Dim fc As FormatCondition

    Dim dictFarben As Object
    Dim keys As Variant

    Dim i As Long
    Dim code As String
    Dim farbeRGB As Long

    Dim topLeftAddress As String

    If lastRow < firstRow Then Exit Sub

    Set rngZiel = wsKal.Range(wsKal.Cells(firstRow, firstDayCol), _
                              wsKal.Cells(lastRow, lastDayCol))

    ' Bestehende bedingte Formatierungen im Tagesbereich löschen,
    ' damit beim erneuten Aufbau keine Regelduplikate entstehen.
    rngZiel.FormatConditions.Delete

    Set dictFarben = StatusFarbDictionary()
    keys = dictFarben.keys

    topLeftAddress = rngZiel.Cells(1, 1).Address(RowAbsolute:=False, ColumnAbsolute:=False)

    For i = LBound(keys) To UBound(keys)

        code = CStr(keys(i))
        farbeRGB = CLng(dictFarben(code))

        Set fc = rngZiel.FormatConditions.Add( _
            Type:=xlExpression, _
            Formula1:="=" & topLeftAddress & "=""" & code & """")

        With fc
            .Interior.Color = farbeRGB
            .Font.Color = RGB(0, 0, 0)
            .StopIfTrue = False
        End With

    Next i

End Sub


' ============================================================
' Ferien im Monatsblock markieren
'
' Quelle:
'   Blatt "Parameter"
'   Tabelle "tblFerien"
'   Spalten:
'       Ferien
'       von
'       bis
'
' Wirkung:
'   - Ferienzeitraum wird in der Zeile oberhalb des Monatsblocks
'     gelb eingefärbt, verbunden und beschriftet.
'   - Wochentagszellen innerhalb der Ferien werden gelb eingefärbt,
'     sofern sie weder Wochenende noch Feiertag sind.
' ============================================================

Private Sub MarkiereFerienMonatsblock( _
    ByVal wsKal As Worksheet, _
    ByVal jahr As Long, _
    ByVal monat As Long, _
    ByVal blockStartRow As Long, _
    ByVal firstDayCol As Long, _
    ByVal daysInMonth As Long)

    Dim wsParam As Worksheet
    Dim tbl As ListObject

    Dim ferienCol As Long
    Dim vonCol As Long
    Dim bisCol As Long

    Dim i As Long
    Dim ferienName As String
    Dim vonDatum As Date
    Dim bisDatum As Date

    Dim monthStart As Date
    Dim monthEnd As Date
    Dim overlapStart As Date
    Dim overlapEnd As Date

    Dim startCol As Long
    Dim endCol As Long
    Dim bannerRow As Long

    Dim d As Date
    Dim tag As Long
    Dim col As Long

    Dim rngBanner As Range

    monthStart = DateSerial(jahr, monat, 1)
    monthEnd = DateSerial(jahr, monat + 1, 0)

    bannerRow = blockStartRow - 1

    Set wsParam = ThisWorkbook.Worksheets("Parameter")
    Set tbl = wsParam.ListObjects("tblFerien")

    ferienCol = tbl.ListColumns("Ferien").Index
    vonCol = tbl.ListColumns("von").Index
    bisCol = tbl.ListColumns("bis").Index

    For i = 1 To tbl.DataBodyRange.Rows.count

        If IsDate(tbl.DataBodyRange.Cells(i, vonCol).Value) And _
           IsDate(tbl.DataBodyRange.Cells(i, bisCol).Value) Then

            ferienName = Trim(CStr(tbl.DataBodyRange.Cells(i, ferienCol).Value))
            vonDatum = CDate(tbl.DataBodyRange.Cells(i, vonCol).Value)
            bisDatum = CDate(tbl.DataBodyRange.Cells(i, bisCol).Value)

            ' Prüfen, ob Ferienzeitraum den aktuellen Monat berührt
            If vonDatum <= monthEnd And bisDatum >= monthStart Then

                If vonDatum < monthStart Then
                    overlapStart = monthStart
                Else
                    overlapStart = vonDatum
                End If

                If bisDatum > monthEnd Then
                    overlapEnd = monthEnd
                Else
                    overlapEnd = bisDatum
                End If

                startCol = firstDayCol + Day(overlapStart) - 1
                endCol = firstDayCol + Day(overlapEnd) - 1

                ' Ferien-Banner oberhalb des Monatsblocks
                Set rngBanner = wsKal.Range(wsKal.Cells(bannerRow, startCol), _
                                            wsKal.Cells(bannerRow, endCol))

                With rngBanner
                    .UnMerge
                    .Merge
                    .Interior.Color = RGB(255, 255, 0)
                    .Value = ferienName & ": " & _
                             Format(vonDatum, "dd.mm.") & " bis " & _
                             Format(bisDatum, "dd.mm.yyyy")
                    .HorizontalAlignment = xlCenter
                    .VerticalAlignment = xlCenter
                    .Font.Bold = True
                    .Font.Color = RGB(192, 0, 0)
                End With

                ' Wochentagszeile innerhalb der Ferien gelb färben,
                ' aber nur bei normalen Wochentagen:
                ' nicht Samstag, nicht Sonntag, nicht Feiertag
                For tag = Day(overlapStart) To Day(overlapEnd)

                    d = DateSerial(jahr, monat, tag)
                    col = firstDayCol + tag - 1

                    If Weekday(d, vbMonday) <= 5 Then
                        If Not IstFeiertag(d) Then
                            wsKal.Cells(blockStartRow, col).Interior.Color = RGB(255, 255, 0)
                        End If
                    End If

                Next tag

            End If

        End If

    Next i

End Sub


' ============================================================
' Prüft, ob ein Datum in tblFeiertage enthalten ist
' ============================================================

Private Function IstFeiertag(ByVal pruefDatum As Date) As Boolean

    Dim wsParam As Worksheet
    Dim tbl As ListObject
    Dim datumCol As Long
    Dim i As Long
    Dim d As Date

    On Error GoTo Fehler

    Set wsParam = ThisWorkbook.Worksheets("Parameter")
    Set tbl = wsParam.ListObjects("tblFeiertage")

    datumCol = tbl.ListColumns("Datum").Index

    For i = 1 To tbl.DataBodyRange.Rows.count

        If IsDate(tbl.DataBodyRange.Cells(i, datumCol).Value) Then
            d = CDate(tbl.DataBodyRange.Cells(i, datumCol).Value)

            If CLng(d) = CLng(pruefDatum) Then
                IstFeiertag = True
                Exit Function
            End If
        End If

    Next i

    IstFeiertag = False
    Exit Function

Fehler:
    IstFeiertag = False

End Function


' ============================================================
' Mapping-Dictionaries aus tblMapping laden
'
' Voraussetzung:
'   Blatt "Parameter"
'   Definierter Name "tblMapping"
'   Spalten:
'       SpeicherCode
'       AnzeigeCode
'
' Bedeutung:
'   X = leere Zelle / Office-Tag
'   Z = -- / Sonstiges
' ============================================================

Private Sub LadeMappingDictionaries( _
    ByRef dictAnzeigeToSpeicher As Object, _
    ByRef dictSpeicherToAnzeige As Object)

    Dim rngMap As Range
    Dim i As Long

    Dim speicherCode As String
    Dim anzeigeCode As String

    Set dictAnzeigeToSpeicher = CreateObject("Scripting.Dictionary")
    Set dictSpeicherToAnzeige = CreateObject("Scripting.Dictionary")

    On Error Resume Next
    Set rngMap = ThisWorkbook.names("tblMapping").RefersToRange
    On Error GoTo 0

    If rngMap Is Nothing Then
        MsgBox "Der definierte Name 'tblMapping' wurde nicht gefunden.", vbExclamation
        Exit Sub
    End If

    For i = 1 To rngMap.Rows.count

        speicherCode = Trim(CStr(rngMap.Cells(i, 1).Value))
        anzeigeCode = Trim(CStr(rngMap.Cells(i, 2).Value))

        If speicherCode <> "" Then

            ' SpeicherCode -> AnzeigeCode
            If Not dictSpeicherToAnzeige.Exists(speicherCode) Then
                dictSpeicherToAnzeige.Add speicherCode, anzeigeCode
            End If

            ' AnzeigeCode -> SpeicherCode
            If Not dictAnzeigeToSpeicher.Exists(anzeigeCode) Then
                dictAnzeigeToSpeicher.Add anzeigeCode, speicherCode
            End If

        End If

    Next i

End Sub


' ============================================================
' Bestehende Kalendereinträge sichern
'
' Struktur:
'   dictKalenderSpeicher(Anzeigename)(Monat) = Monatsvektor
'
' Beispiel:
'   dictKalenderSpeicher("Alpha, Anna")(1) = "XXACB..."
'
' Ein Monatsvektor hat exakt so viele Zeichen wie der Monat Tage hat.
' Position 1 = Tag 1, Position 2 = Tag 2 usw.
' ============================================================

Private Function SichereKalendereintraege( _
    ByVal wsKal As Worksheet, _
    ByVal jahr As Long, _
    ByVal firstDayCol As Long, _
    ByVal lastDayCol As Long, _
    ByVal dictAnzeigeToSpeicher As Object) As Object

    Dim dictKalenderSpeicher As Object
    Dim r As Long
    Dim c As Long

    Dim lastSearchRow As Long
    Dim currentMonth As Long
    Dim daysInMonth As Long

    Dim blockStartRow As Long
    Dim blockEndRow As Long

    Dim nameValue As String
    Dim cellValue As String
    Dim speicherCode As String

    Dim monatDict As Object
    Dim monatsVektor As String

    Dim tag As Long

    Set dictKalenderSpeicher = CreateObject("Scripting.Dictionary")

    lastSearchRow = wsKal.Cells(wsKal.Rows.count, "A").End(xlUp).Row

    If lastSearchRow < 5 Then
        Set SichereKalendereintraege = dictKalenderSpeicher
        Exit Function
    End If

    For currentMonth = 1 To 12

        blockStartRow = FindeMonatsblockStartzeile(wsKal, currentMonth, jahr, 5, lastSearchRow)

        If blockStartRow > 0 Then

            blockEndRow = FindeMonatsblockEndzeile(wsKal, blockStartRow, lastSearchRow)
            daysInMonth = Day(DateSerial(jahr, currentMonth + 1, 0))

            For r = blockStartRow + 1 To blockEndRow

                nameValue = Trim(CStr(wsKal.Cells(r, "C").Value))

                ' Nur Mitarbeiterzeilen sichern:
                ' - Name in Spalte C vorhanden
                ' - mindestens eine Tageszelle mit Dropdown oder Inhalt vorhanden
                If nameValue <> "" Then

                    If ZeileHatKalenderrelevanz(wsKal, r, firstDayCol, firstDayCol + daysInMonth - 1) Then

                        monatsVektor = ""

                        For tag = 1 To daysInMonth

                            c = firstDayCol + tag - 1
                            cellValue = Trim(CStr(wsKal.Cells(r, c).Value))

                            If cellValue = "" Then
                                speicherCode = "X"
                            ElseIf Not dictAnzeigeToSpeicher Is Nothing Then
                                If dictAnzeigeToSpeicher.Exists(cellValue) Then
                                    speicherCode = CStr(dictAnzeigeToSpeicher(cellValue))
                                Else
                                    speicherCode = "X"
                                End If
                            Else
                                speicherCode = "X"
                            End If

                            monatsVektor = monatsVektor & speicherCode

                        Next tag

                        If Not dictKalenderSpeicher.Exists(nameValue) Then
                            Set monatDict = CreateObject("Scripting.Dictionary")
                            dictKalenderSpeicher.Add nameValue, monatDict
                        Else
                            Set monatDict = dictKalenderSpeicher(nameValue)
                        End If

                        monatDict(currentMonth) = monatsVektor

                    End If

                End If

            Next r

        End If

    Next currentMonth

    Debug.Print "Kalendereinträge gesichert: " & dictKalenderSpeicher.count & " Mitarbeiter"

    Set SichereKalendereintraege = dictKalenderSpeicher

End Function


' ============================================================
' Gesicherte Kalendereinträge zurückschreiben
'
' X wird nicht sichtbar geschrieben:
'   X -> Zelle bleibt leer
'
' Alle anderen SpeicherCodes werden über tblMapping zurückübersetzt:
'   A -> FD
'   B -> SD
'   ...
'   Z -> --
' ============================================================

Private Sub SchreibeKalendereintraegeZurueck( _
    ByVal wsKal As Worksheet, _
    ByVal jahr As Long, _
    ByVal firstDayCol As Long, _
    ByVal lastDayCol As Long, _
    ByVal dictKalenderSpeicher As Object, _
    ByVal dictSpeicherToAnzeige As Object)

    Dim r As Long
    Dim c As Long

    Dim lastSearchRow As Long
    Dim currentMonth As Long
    Dim daysInMonth As Long

    Dim blockStartRow As Long
    Dim blockEndRow As Long

    Dim nameValue As String
    Dim monatDict As Object
    Dim monatsVektor As String

    Dim tag As Long
    Dim speicherCode As String
    Dim anzeigeCode As String

    If dictKalenderSpeicher Is Nothing Then Exit Sub

    lastSearchRow = wsKal.Cells(wsKal.Rows.count, "A").End(xlUp).Row

    If lastSearchRow < 5 Then Exit Sub

    For currentMonth = 1 To 12

        blockStartRow = FindeMonatsblockStartzeile(wsKal, currentMonth, jahr, 5, lastSearchRow)

        If blockStartRow > 0 Then

            blockEndRow = FindeMonatsblockEndzeile(wsKal, blockStartRow, lastSearchRow)
            daysInMonth = Day(DateSerial(jahr, currentMonth + 1, 0))

            For r = blockStartRow + 1 To blockEndRow

                nameValue = Trim(CStr(wsKal.Cells(r, "C").Value))

                If nameValue <> "" Then

                    If dictKalenderSpeicher.Exists(nameValue) Then

                        Set monatDict = dictKalenderSpeicher(nameValue)

                        If monatDict.Exists(currentMonth) Then

                            monatsVektor = CStr(monatDict(currentMonth))

                            For tag = 1 To daysInMonth

                                If tag <= Len(monatsVektor) Then

                                    speicherCode = Mid(monatsVektor, tag, 1)
                                    c = firstDayCol + tag - 1

                                    If speicherCode = "X" Then
                                        wsKal.Cells(r, c).ClearContents
                                    ElseIf Not dictSpeicherToAnzeige Is Nothing Then
                                        If dictSpeicherToAnzeige.Exists(speicherCode) Then
                                            anzeigeCode = CStr(dictSpeicherToAnzeige(speicherCode))
                                            wsKal.Cells(r, c).Value = anzeigeCode
                                        Else
                                            wsKal.Cells(r, c).ClearContents
                                        End If
                                    Else
                                        wsKal.Cells(r, c).ClearContents
                                    End If

                                End If

                            Next tag

                        End If

                    End If

                End If

            Next r

        End If

    Next currentMonth

    Debug.Print "Kalendereinträge zurückgeschrieben."

End Sub


' ============================================================
' Monatsblock-Startzeile finden
'
' Sucht in Spalte A nach dem verbundenen Monatsnamen.
' ============================================================

Private Function FindeMonatsblockStartzeile( _
    ByVal wsKal As Worksheet, _
    ByVal monat As Long, _
    ByVal jahr As Long, _
    ByVal firstSearchRow As Long, _
    ByVal lastSearchRow As Long) As Long

    Dim r As Long
    Dim gesuchterMonat As String
    Dim cellText As String

    gesuchterMonat = LCase(Format(DateSerial(jahr, monat, 1), "MMMM"))

    For r = firstSearchRow To lastSearchRow

        cellText = LCase(Trim(CStr(wsKal.Cells(r, "A").Value)))

        If cellText = gesuchterMonat Then
            FindeMonatsblockStartzeile = r
            Exit Function
        End If

    Next r

    FindeMonatsblockStartzeile = 0

End Function


' ============================================================
' Monatsblock-Endzeile finden
'
' Da der Monatsname in Spalte A als verbundener Bereich steht,
' kann die Endzeile aus dem MergeArea-Bereich gelesen werden.
' ============================================================

Private Function FindeMonatsblockEndzeile( _
    ByVal wsKal As Worksheet, _
    ByVal blockStartRow As Long, _
    ByVal lastSearchRow As Long) As Long

    If wsKal.Cells(blockStartRow, "A").MergeCells Then
        With wsKal.Cells(blockStartRow, "A").MergeArea
            FindeMonatsblockEndzeile = .Row + .Rows.count - 1
        End With
    Else
        FindeMonatsblockEndzeile = blockStartRow
    End If

End Function


' ============================================================
' Prüft, ob eine Zeile kalenderrelevante Tageszellen enthält.
'
' Für Version 2.0:
'   Eine Zeile gilt als relevant, wenn im Tagesbereich mindestens
'   eine Zelle Datenüberprüfung besitzt oder einen Eintrag enthält.
'
' Dadurch werden Statuszeilen, Leerzeilen und KW-Zeilen ignoriert.
' ============================================================

Private Function ZeileHatKalenderrelevanz( _
    ByVal wsKal As Worksheet, _
    ByVal targetRow As Long, _
    ByVal firstCol As Long, _
    ByVal lastCol As Long) As Boolean

    Dim c As Long

    For c = firstCol To lastCol

        If ZelleHatDatenueberpruefung(wsKal.Cells(targetRow, c)) Then
            ZeileHatKalenderrelevanz = True
            Exit Function
        End If

        If Trim(CStr(wsKal.Cells(targetRow, c).Value)) <> "" Then
            ZeileHatKalenderrelevanz = True
            Exit Function
        End If

    Next c

    ZeileHatKalenderrelevanz = False

End Function


' ============================================================
' Prüft, ob eine Zelle Datenüberprüfung besitzt
' ============================================================

Private Function ZelleHatDatenueberpruefung(ByVal rng As Range) As Boolean

    On Error GoTo KeineValidation

    If rng.Validation.Type = xlValidateList Then
        ZelleHatDatenueberpruefung = True
        Exit Function
    End If

KeineValidation:
    ZelleHatDatenueberpruefung = False

End Function


' ============================================================
' Hilfsfunktion:
' Gibt den Index einer ListObject-Spalte zurück.
' Falls die Spalte nicht existiert, wird 0 zurückgegeben.
' ============================================================

Private Function HoleTabellenspaltenIndex( _
    ByVal tbl As ListObject, _
    ByVal spaltenName As String) As Long

    On Error GoTo NichtGefunden

    HoleTabellenspaltenIndex = tbl.ListColumns(spaltenName).Index
    Exit Function

NichtGefunden:
    HoleTabellenspaltenIndex = 0

End Function


' ============================================================
' Überschriften für die ausgeblendeten Hilfsspalten
'
' Diese Überschriften dienen der Nachvollziehbarkeit,
' falls die Hilfsspalten eingeblendet werden.
' ============================================================

Private Sub SchreibeHilfsspaltenUeberschriften(ByVal wsKal As Worksheet)

    wsKal.Range("AJ4").Value = "Urlaub IST"
    wsKal.Range("AK4").Value = "MW"
    wsKal.Range("AL4").Value = "K"
    wsKal.Range("AM4").Value = "Sonst"
    wsKal.Range("AN4").Value = "Büro"
    wsKal.Range("AO4").Value = "Urlaub Soll"

    With wsKal.Range("AJ4:AO4")
        .Font.Bold = True
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
        .Interior.Color = RGB(242, 242, 242)
        .Borders.LineStyle = xlContinuous
    End With

End Sub


' ============================================================
' Blattschutz ausschalten
'
' Wird zu Beginn des Neuaufbaus aufgerufen, damit das Makro
' den Kalender vollständig neu erzeugen kann.
' ============================================================

Private Sub SchalteBlattschutzAus(ByVal wsKal As Worksheet)

    On Error Resume Next

    If Len(KALENDER_SCHUTZ_PASSWORT) > 0 Then
        wsKal.Unprotect Password:=KALENDER_SCHUTZ_PASSWORT
    Else
        wsKal.Unprotect
    End If

    On Error GoTo 0

End Sub


' ============================================================
' Blattschutz einschalten
'
' Wirkung:
'   - gesperrte Zellen können nicht bearbeitet werden
'   - entsperrte Dropdown-Zellen bleiben editierbar
'   - Formeln, Statuszeilen, Statistik, Wochenenden,
'     Feiertage und Hilfsspalten sind geschützt
'
' UserInterfaceOnly:=True erlaubt Makros weiterhin Änderungen,
' solange die Datei in derselben Excel-Sitzung geöffnet ist.
' ============================================================

Private Sub SchalteBlattschutzEin(ByVal wsKal As Worksheet)

    On Error Resume Next

    If Len(KALENDER_SCHUTZ_PASSWORT) > 0 Then

        wsKal.Protect _
            Password:=KALENDER_SCHUTZ_PASSWORT, _
            DrawingObjects:=True, _
            Contents:=True, _
            Scenarios:=True, _
            UserInterfaceOnly:=True, _
            AllowFormattingCells:=False, _
            AllowFormattingColumns:=False, _
            AllowFormattingRows:=False, _
            AllowInsertingColumns:=False, _
            AllowInsertingRows:=False, _
            AllowDeletingColumns:=False, _
            AllowDeletingRows:=False, _
            AllowSorting:=False, _
            AllowFiltering:=False, _
            AllowUsingPivotTables:=False

    Else

        wsKal.Protect _
            DrawingObjects:=True, _
            Contents:=True, _
            Scenarios:=True, _
            UserInterfaceOnly:=True, _
            AllowFormattingCells:=False, _
            AllowFormattingColumns:=False, _
            AllowFormattingRows:=False, _
            AllowInsertingColumns:=False, _
            AllowInsertingRows:=False, _
            AllowDeletingColumns:=False, _
            AllowDeletingRows:=False, _
            AllowSorting:=False, _
            AllowFiltering:=False, _
            AllowUsingPivotTables:=False

    End If

    ' Im Betrieb sollen nur entsperrte Zellen auswählbar sein.
    wsKal.EnableSelection = xlUnlockedCells

    On Error GoTo 0

End Sub

