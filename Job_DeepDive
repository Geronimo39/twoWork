# SCHRITT 3: Letzter Spool-File des Jobs
# ══════════════════════════════════════════════════════════════════════════════
def get_last_spool_file(conn, job_name: str) -> pd.DataFrame:
    """
    Sucht den letzten Spool-File des Jobs und liest dessen Inhalt.
    Versucht QSYS2.OUTPUT_QUEUE_ENTRIES, Fallback via WRKSPLF → Outfile.
    """
    print(f"\n{'='*60}")
    print(f"[3] Letzter Spool-File für Job: {job_name}")
    print(f"{'='*60}")

    # Variante A: QSYS2.OUTPUT_QUEUE_ENTRIES (V7+)
    sql_oqe = f"""
        SELECT
            JOB_NAME,
            JOB_USER,
            JOB_NUMBER,
            SPOOLED_FILE_NAME,
            FILE_NUMBER,
            STATUS,
            CREATION_TIMESTAMP,
            OUTPUT_QUEUE_NAME,
            OUTPUT_QUEUE_LIBRARY,
            FORM_TYPE,
            COPIES,
            PAGES,
            CURRENT_PAGE
        FROM QSYS2.OUTPUT_QUEUE_ENTRIES
        WHERE UPPER(JOB_NAME) LIKE UPPER('%{job_name}%')
        ORDER BY CREATION_TIMESTAMP DESC
        FETCH FIRST 10 ROWS ONLY
    """
    df_oqe = run_query(conn, sql_oqe, "OUTPUT_QUEUE_ENTRIES")

    if df_oqe.empty:
        # Variante B: WRKSPLF OUTPUT(*OUTFILE)
        print("  Fallback: WRKSPLF OUTPUT(*OUTFILE)...")
        cl = (
            f"WRKSPLF SELECT(*ALL {job_name} *ALL *ALL) "
            f"OUTPUT(*OUTFILE) "
            f"OUTFILE({MY_SCHEMA}/SPLF_OUT) "
            f"OUTMBR(*FIRST *REPLACE)"
        )
        ok = run_cl(conn, cl)
        if ok:
            df_oqe = run_query(conn, f"SELECT * FROM {MY_SCHEMA}.SPLF_OUT", "SPLF_OUT Outfile")
            df_oqe = drop_binary_cols(df_oqe)

    if df_oqe.empty:
        print("  ✗ Kein Spool-File gefunden")
        return pd.DataFrame()

    print(f"\n  Gefundene Spool-Files ({len(df_oqe)}):")
    for _, row in df_oqe.head(5).iterrows():
        ts  = row.get("CREATION_TIMESTAMP", row.get("SPLFCDT", "?"))
        fnm = row.get("SPOOLED_FILE_NAME",  row.get("SPLFNM",  "?"))
        jnb = row.get("JOB_NUMBER",         row.get("SPLJNB",  "?"))
        print(f"    • {fnm} | Job# {jnb} | {ts}")

    # Neuesten Spool-File lesen via CPYSPLF → Outfile
    latest = df_oqe.iloc[0]
    splf_name = str(latest.get("SPOOLED_FILE_NAME", latest.get("SPLFNM", ""))).strip()
    job_user  = str(latest.get("JOB_USER",  latest.get("SPLUSRNAM", "*ALL"))).strip()
    job_nbr   = str(latest.get("JOB_NUMBER", latest.get("SPLJNB", "*ONLY"))).strip()

    df_content = pd.DataFrame()

    if splf_name:
        print(f"\n  Lese Inhalt von Spool-File: {splf_name} (Job# {job_nbr})...")

        # CPYSPLF → Textdatei im IFS (sauberste Methode)
        ifs_path = f"/tmp/spool_{job_name}_{job_nbr}.txt"
        cl_copy  = (
            f"CPYSPLF FILE({splf_name}) "
            f"TOFILE(*TOSTMF) "
            f"JOB({job_nbr}/{job_user}/{job_name}) "
            f"SPLNBR(*LAST) "
            f"TOSTMF('{ifs_path}') "
            f"STMFOPT(*REPLACE) "
            f"WSCST(*NONE)"
        )
        ok_ifs = run_cl(conn, cl_copy)

        if ok_ifs:
            # IFS-Datei via SQL lesen
            sql_ifs = f"""
                SELECT LINE_NUMBER,
                       CAST(CAST(LINE AS VARCHAR(256) CCSID 1252) AS VARCHAR(256)) AS LINE_TEXT
                FROM TABLE(QSYS2.IFS_READ_UTF8(
                    PATH_NAME => '{ifs_path}',
                    END_OF_LINE => '*ANY',
                    MAXIMUM_LINE_LENGTH => 256
                )) AS T
                FETCH FIRST {MAX_SPOOL_LINES} ROWS ONLY
            """
            df_content = run_query(conn, sql_ifs, f"IFS Spool-Inhalt (max. {MAX_SPOOL_LINES} Zeilen)")

        if df_content.empty:
            # Fallback: CPYSPLF in DB2-Datei
            print("  Fallback: CPYSPLF → DB2-Datei...")
            cl_db2 = (
                f"CPYSPLF FILE({splf_name}) "
                f"TOFILE({MY_SCHEMA}/SPLCONT_OUT) "
                f"JOB({job_nbr}/{job_user}/{job_name}) "
                f"SPLNBR(*LAST) "
                f"MBROPT(*REPLACE)"
            )
            ok_db2 = run_cl(conn, cl_db2)
            if ok_db2:
                df_content = run_query(
                    conn,
                    f"SELECT * FROM {MY_SCHEMA}.SPLCONT_OUT FETCH FIRST {MAX_SPOOL_LINES} ROWS ONLY",
                    "SPLCONT_OUT Outfile"
                )
                df_content = drop_binary_cols(df_content)

    # Konsolenausgabe der ersten Zeilen
    if not df_content.empty:
        print(f"\n  ── Spool-File Inhalt (erste {min(30, len(df_content))} Zeilen) ──")
        text_col = df_content.columns[-1]  # letzte Spalte = Textinhalt
        for _, row in df_content.head(30).iterrows():
            print(f"  {str(row[text_col])}")
        if len(df_content) > 30:
            print(f"  ... ({len(df_content) - 30} weitere Zeilen im Excel)")

    return pd.concat([df_oqe, df_content], ignore_index=True) if not df_content.empty else df_oqe


