# SCHRITT 2: Call-Tree via DSPPGMREF (rekursiv)
# ══════════════════════════════════════════════════════════════════════════════
def get_call_tree(conn, root_pgm: str, root_lib: str, max_depth: int = MAX_CALL_DEPTH) -> pd.DataFrame:
    """
    Baut einen Call-Tree rekursiv auf:
    root_pgm ruft → PGM_A, PGM_B ...
    PGM_A ruft → PGM_C, PGM_D ...  usw.

    Verwendet DSPPGMREF OUTPUT(*OUTFILE) → STEFAN.PGMREF_OUT
    """
    print(f"\n{'='*60}")
    print(f"[2] Call-Tree für: {root_lib}/{root_pgm} (max. Tiefe {max_depth})")
    print(f"{'='*60}")

    all_edges   = []   # Liste von (depth, caller_lib, caller, callee_lib, callee, obj_type)
    visited     = set()
    queue       = [(root_pgm.strip(), root_lib.strip(), 0)]  # (pgm, lib, depth)

    while queue:
        pgm, lib, depth = queue.pop(0)
        key = f"{lib}/{pgm}"

        if key in visited or depth > max_depth:
            continue
        visited.add(key)

        # DSPPGMREF für dieses Programm
        cl = (
            f"DSPPGMREF PGM({lib}/{pgm}) "
            f"OUTPUT(*OUTFILE) "
            f"OUTFILE({MY_SCHEMA}/PGMREF_OUT) "
            f"OUTMBR(*FIRST *REPLACE)"
        )
        ok = run_cl(conn, cl, silent=True)
        if not ok:
            continue

        try:
            df = pd.read_sql(f"SELECT * FROM {MY_SCHEMA}.PGMREF_OUT", conn)
            df = drop_binary_cols(df)
        except Exception:
            continue

        if df.empty:
            continue

        # Spaltennamen normalisieren (pre-V7 kann variieren)
        cols = {c.upper(): c for c in df.columns}

        # Felder: WHRECP/WHRELI = referenziertes Objekt + Library
        #         WHOBJT = Objekttyp (*PGM, *SRVPGM, *FILE, *DTAARA ...)
        ref_pgm_col = cols.get("WHRECP", cols.get("REFPGM",  cols.get("WHRFNM", None)))
        ref_lib_col = cols.get("WHRELI", cols.get("REFLIB",  cols.get("WHRFLB", None)))
        obj_typ_col = cols.get("WHOBJT", cols.get("REFOBJT", cols.get("WHRFTP", None)))
        src_pgm_col = cols.get("WHPNAM", cols.get("PGMNAM",  cols.get("WHRPNM", None)))

        for _, row in df.iterrows():
            callee     = str(row[ref_pgm_col]).strip() if ref_pgm_col else "?"
            callee_lib = str(row[ref_lib_col]).strip() if ref_lib_col else "?"
            obj_type   = str(row[obj_typ_col]).strip() if obj_typ_col else "?"
            caller     = str(row[src_pgm_col]).strip() if src_pgm_col else pgm

            if not callee or callee in ("", "*N", "?"):
                continue

            all_edges.append({
                "DEPTH":      depth + 1,
                "CALLER_LIB": lib,
                "CALLER":     caller if caller else pgm,
                "CALLEE_LIB": callee_lib,
                "CALLEE":     callee,
                "OBJ_TYPE":   obj_type,
                "EDGE_KEY":   f"{lib}/{pgm} → {callee_lib}/{callee}"
            })

            # Nur Programme und Service-Programme weiter verfolgen
            if obj_type in ("*PGM", "*SRVPGM", "PGM", "SRVPGM") and depth + 1 <= max_depth:
                queue.append((callee, callee_lib, depth + 1))

    df_tree = pd.DataFrame(all_edges).drop_duplicates(subset=["EDGE_KEY"])

    # Baumdarstellung für Konsole
    print(f"\n  Call-Tree ({len(df_tree)} Kanten, {len(visited)} Programme analysiert):\n")
    _print_tree(df_tree, root_pgm, root_lib, depth=0, prefix="")

    return df_tree


def _print_tree(df: pd.DataFrame, pgm: str, lib: str, depth: int, prefix: str):
    """Rekursive Konsolenausgabe des Call-Trees."""
    if depth > MAX_CALL_DEPTH:
        return
    children = df[(df["CALLER"].str.strip().str.upper() == pgm.upper()) &
                  (df["CALLER_LIB"].str.strip().str.upper() == lib.upper())]
    for i, (_, row) in enumerate(children.iterrows()):
        is_last    = (i == len(children) - 1)
        connector  = "└── " if is_last else "├── "
        ext_prefix = "    " if is_last else "│   "
        print(f"  {prefix}{connector}{row['CALLEE_LIB']}/{row['CALLEE']}  [{row['OBJ_TYPE']}]")
        _print_tree(df, row["CALLEE"], row["CALLEE_LIB"], depth + 1, prefix + ext_prefix)


