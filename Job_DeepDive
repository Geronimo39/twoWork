"""
AS/400 Job Deep-Dive: Call-Tree + letzter Spool-File
=====================================================
Gibt einen Job-Namen ein → liefert:
  1. JOBD des Jobs (Initiales Programm, Queue, User, ...)
  2. Call-Tree via DSPPGMREF (rekursiv, als Baumstruktur)
  3. Letzten Spool-File-Inhalt des Jobs (via WRKSPLF → Outfile)
  4. QHST-Einträge für diesen Job (letzte N Tage)
  5. Excel-Export + Konsolenausgabe

Konfiguration:
"""

import pyodbc
import pandas as pd
from datetime import datetime, timedelta
from pathlib import Path
import sys

# ── Konfiguration ────────────────────────────────────────────────────────────
DSN            = "AS400"          # ODBC-DSN Name
MY_SCHEMA      = "STEFAN"         # Dein Write-Access Schema
OUTPUT_DIR     = Path(".")

# ► Hier den Job-Namen eintragen (oder beim Start als Argument übergeben):
JOB_NAME_INPUT = "MEIN_JOB"       # z.B. "TAGEND_NOP" oder "VRDAT_LOAD"

HQST_DAYS_BACK     = 14           # Wie viele Tage QHST rückwärts analysieren
MAX_CALL_DEPTH     = 6            # Maximale Rekursionstiefe für Call-Tree
MAX_SPOOL_LINES    = 500          # Maximale Zeilen aus dem Spool-File anzeigen
# ─────────────────────────────────────────────────────────────────────────────


def connect():
    conn = pyodbc.connect(f"DSN={DSN}", autocommit=True)
    conn.setdecoding(pyodbc.SQL_CHAR, encoding="cp1252")
    conn.setdecoding(pyodbc.SQL_WCHAR, encoding="cp1252")
    conn.setencoding(encoding="cp1252")
    return conn


def run_query(conn, sql, label=""):
    try:
        df = pd.read_sql(sql, conn)
        print(f"  ✓ {label}: {len(df)} Zeilen")
        return df
    except Exception as e:
        print(f"  ✗ {label}: {e}")
        return pd.DataFrame()


def run_cl(conn, cl_command, silent=False):
    escaped = cl_command.replace("'", "''")
    length  = len(cl_command)
    sql = f"CALL QSYS2.QCMDEXC('{escaped}', {length}.00000)"
    try:
        conn.execute(sql)
        return True
    except Exception as e:
        if not silent:
            print(f"    CL-Fehler: {e}")
        return False


def drop_binary_cols(df):
    bad = [c for c in df.columns if df[c].dtype == object and
           df[c].dropna().apply(lambda x: isinstance(x, (bytes, bytearray))).any()]
    return df.drop(columns=bad) if bad else df


# ══════════════════════════════════════════════════════════════════════════════
# SCHRITT 1: Job Description des Jobs finden
# ══════════════════════════════════════════════════════════════════════════════
def get_job_description(conn, job_name: str) -> dict:
    """
    Sucht die Job Description für den gegebenen Job-Namen.
    Versucht zuerst SCHEDULED_JOB_INFO, dann JOB_DESCRIPTION_INFO direkt.
    """
    print(f"\n{'='*60}")
    print(f"[1] Job Description für: {job_name}")
    print(f"{'='*60}")

    result = {
        "job_name":    job_name,
        "jobd_name":   None,
        "jobd_lib":    None,
        "inl_pgm":     None,
        "inl_pgm_lib": None,
        "job_queue":   None,
        "user":        None,
        "raw_df":      pd.DataFrame()
    }

    # Variante A: Job in SCHEDULED_JOB_INFO nachschlagen
    sql_sched = f"""
        SELECT *
        FROM QSYS2.SCHEDULED_JOB_INFO
        WHERE UPPER(JOB_NAME) LIKE UPPER('%{job_name}%')
        FETCH FIRST 5 ROWS ONLY
    """
    df_sched = run_query(conn, sql_sched, "SCHEDULED_JOB_INFO (Job-Suche)")

    if not df_sched.empty:
        row = df_sched.iloc[0]
        result["jobd_name"] = str(row.get("JOB_DESCRIPTION", "")).strip()
        result["jobd_lib"]  = str(row.get("JOB_DESCRIPTION_LIBRARY", "")).strip()
        result["job_queue"] = str(row.get("JOB_QUEUE_NAME", "")).strip()
        result["raw_df"]    = drop_binary_cols(df_sched)
        print(f"  → JOBD: {result['jobd_lib']}/{result['jobd_name']}")

    # Variante B: JOBD direkt nachschlagen (liefert INLPGM)
    if result["jobd_name"] and result["jobd_name"] not in ("", "None"):
        sql_jobd = f"""
            SELECT *
            FROM QSYS2.JOB_DESCRIPTION_INFO
            WHERE UPPER(JOB_DESCRIPTION_NAME) = UPPER('{result["jobd_name"]}')
              AND UPPER(JOB_DESCRIPTION_LIBRARY) = UPPER('{result["jobd_lib"]}')
            FETCH FIRST 1 ROWS ONLY
        """
        df_jobd = run_query(conn, sql_jobd, "JOB_DESCRIPTION_INFO (INLPGM)")
        if not df_jobd.empty:
            df_jobd = drop_binary_cols(df_jobd)
            row2 = df_jobd.iloc[0]
            for col in df_jobd.columns:
                if "INLPGM" in col.upper() or "INITIAL" in col.upper():
                    result["inl_pgm"]     = str(row2.get(col, "")).strip()
                if "INLPGMLIB" in col.upper():
                    result["inl_pgm_lib"] = str(row2.get(col, "")).strip()
            if result["raw_df"].empty:
                result["raw_df"] = df_jobd
            else:
                result["raw_df"] = pd.concat([result["raw_df"], df_jobd], ignore_index=True)

    # Variante C: Suche in JOB_DESCRIPTION_INFO nach Name-Pattern
    sql_jobd2 = f"""
        SELECT *
        FROM QSYS2.JOB_DESCRIPTION_INFO
        WHERE UPPER(JOB_DESCRIPTION_NAME) LIKE UPPER('%{job_name}%')
        FETCH FIRST 10 ROWS ONLY
    """
    df_jobd2 = run_query(conn, sql_jobd2, "JOB_DESCRIPTION_INFO (Name-Pattern)")
    if not df_jobd2.empty:
        df_jobd2 = drop_binary_cols(df_jobd2)
        if result["raw_df"].empty:
            result["raw_df"] = df_jobd2
        else:
            result["raw_df"] = pd.concat([result["raw_df"], df_jobd2], ignore_index=True)

    # Konsolenausgabe
    print(f"\n  Job:        {result['job_name']}")
    print(f"  JOBD:       {result['jobd_lib']}/{result['jobd_name']}")
    print(f"  Init.Pgm:   {result['inl_pgm_lib']}/{result['inl_pgm']}")
    print(f"  Job Queue:  {result['job_queue']}")

    return result


