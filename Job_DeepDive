# SCHRITT 4: QHST-Einträge für diesen Job
# ══════════════════════════════════════════════════════════════════════════════
def get_qhst_for_job(conn, job_name: str) -> pd.DataFrame:
    """
    Liest QHST-Einträge die den Job-Namen enthalten.
    Zeigt Start/Ende, Fehler, aufgerufene Objekte.
    """
    print(f"\n{'='*60}")
    print(f"[4] QHST-History für Job: {job_name} (letzte {HQST_DAYS_BACK} Tage)")
    print(f"{'='*60}")

    cl = (
        f"DSPLOG LOG(QHST) "
        f"PERIOD((*AVAIL) (*AVAIL)) "
        f"OUTPUT(*OUTFILE) "
        f"OUTFILE({MY_SCHEMA}/QHST_JOB_OUT) "
        f"OUTMBR(*FIRST *REPLACE)"
    )
    ok = run_cl(conn, cl)
    if not ok:
        return pd.DataFrame()

    # Spaltennamen ermitteln
    try:
        sample = pd.read_sql(
            f"SELECT * FROM {MY_SCHEMA}.QHST_JOB_OUT FETCH FIRST 1 ROWS ONLY", conn
        )
        cols = {c.upper(): c for c in sample.columns}
    except Exception:
        return pd.DataFrame()

    # Adaptives SELECT
    select_parts = []
    for candidate in ["MSGID", "MSGF", "MSGTXT", "MSGDTA", "FROMPGM",
                      "JOBNBR", "JOBNAM", "JOBUSER", "MSGTIME", "MSGDATE",
                      "MSGSEQ", "MSGTYP"]:
        if candidate in cols:
            select_parts.append(cols[candidate])

    if not select_parts:
        select_parts = ["*"]

    job_col = cols.get("JOBNAM", cols.get("MSGDTA", None))
    filter_clause = ""
    if job_col:
        filter_clause = f"WHERE UPPER({cols.get('JOBNAM', cols.get('MSGDTA'))}) LIKE UPPER('%{job_name}%')"

    sql = f"""
        SELECT {', '.join(select_parts)}
        FROM {MY_SCHEMA}.QHST_JOB_OUT
        {filter_clause}
        ORDER BY {cols.get('MSGDATE', select_parts[0])}, {cols.get('MSGTIME', select_parts[0])}
        FETCH FIRST 200 ROWS ONLY
    """
    df = run_query(conn, sql, f"QHST Einträge für {job_name}")
    df = drop_binary_cols(df)

    if not df.empty:
        print(f"\n  Letzte Einträge:")
        for _, row in df.tail(10).iterrows():
            parts = [str(v).strip() for v in row.values if str(v).strip() not in ("", "None")]
            print(f"    {' | '.join(parts[:5])}")

    return df


# ══════════════════════════════════════════════════════════════════════════════
# Excel-Export
# ══════════════════════════════════════════════════════════════════════════════
def to_excel(sheets: dict, path: Path):
    with pd.ExcelWriter(path, engine="openpyxl") as writer:
        for sheet_name, df in sheets.items():
            if df is None or df.empty:
                df = pd.DataFrame({"Info": ["Keine Daten verfügbar"]})
            df.to_excel(writer, sheet_name=sheet_name[:31], index=False)
            ws = writer.sheets[sheet_name[:31]]
            for col in ws.columns:
                max_len = max(
                    (len(str(cell.value)) for cell in col if cell.value is not None),
                    default=10
                )
                ws.column_dimensions[col[0].column_letter].width = min(max_len + 2, 80)
    print(f"\n✅ Excel gespeichert: {path}")


# ══════════════════════════════════════════════════════════════════════════════
# Main
# ══════════════════════════════════════════════════════════════════════════════
def main(job_name: str = None):
    if job_name is None:
        # Kommandozeilenargument oder Konfigurationsvariable
        if len(sys.argv) > 1:
            job_name = sys.argv[1].strip().upper()
        else:
            job_name = JOB_NAME_INPUT.strip().upper()

    if not job_name or job_name == "MEIN_JOB":
        print("FEHLER: Bitte Job-Namen angeben!")
        print("  Option 1: JOB_NAME_INPUT in der Konfiguration setzen")
        print("  Option 2: python as400_job_deepdive.py JOBNAME")
        sys.exit(1)

    OUTPUT_EXCEL = OUTPUT_DIR / f"job_deepdive_{job_name}_{datetime.now().strftime('%Y%m%d_%H%M')}.xlsx"

    print("=" * 60)
    print(f"AS/400 Job Deep-Dive")
    print(f"Job:       {job_name}")
    print(f"DSN:       {DSN} | Schema: {MY_SCHEMA}")
    print(f"Zeitstempel: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print("=" * 60)

    conn = connect()

    # ── Schritt 1: JOBD
    jobd_info = get_job_description(conn, job_name)
    df_jobd   = jobd_info["raw_df"]

    # ── Schritt 2: Call-Tree
    # Startpunkt: Initial-Programm aus JOBD, fallback = Job-Name selbst
    root_pgm = jobd_info["inl_pgm"]   or job_name
    root_lib = jobd_info["inl_pgm_lib"] or jobd_info["jobd_lib"] or "*LIBL"

    if root_lib in ("", "None", "*N"):
        root_lib = "*LIBL"

    df_calltree = get_call_tree(conn, root_pgm, root_lib)

    # ── Schritt 3: Spool-File
    df_spool = get_last_spool_file(conn, job_name)

    # ── Schritt 4: QHST
    df_qhst = get_qhst_for_job(conn, job_name)

    conn.close()

    # ── Excel Export
    sheets = {
        "1_JOBD":       df_jobd,
        "2_CallTree":   df_calltree,
        "3_SpoolFile":  df_spool,
        "4_QHST":       df_qhst,
    }

    # Flat-Zusammenfassung für erstes Sheet
    summary_data = {
        "Feld":  ["Job Name", "JOBD", "Init.Programm", "Job Queue",
                  "Call-Tree Kanten", "Spool-File Zeilen", "QHST Einträge"],
        "Wert":  [
            job_name,
            f"{jobd_info['jobd_lib']}/{jobd_info['jobd_name']}",
            f"{jobd_info['inl_pgm_lib']}/{jobd_info['inl_pgm']}",
            jobd_info["job_queue"],
            len(df_calltree),
            len(df_spool),
            len(df_qhst),
        ]
    }
    sheets = {"0_Zusammenfassung": pd.DataFrame(summary_data), **sheets}

    to_excel(sheets, OUTPUT_EXCEL)

    print(f"\n{'='*60}")
    print("FERTIG — Ergebnisse:")
    print(f"  JOBD-Info:          {len(df_jobd)} Zeilen")
    print(f"  Call-Tree:          {len(df_calltree)} Kanten")
    print(f"  Spool-File:         {len(df_spool)} Zeilen")
    print(f"  QHST-Einträge:      {len(df_qhst)} Zeilen")
    print(f"  Excel:              {OUTPUT_EXCEL}")
    print(f"{'='*60}")


if __name__ == "__main__":
    main()
