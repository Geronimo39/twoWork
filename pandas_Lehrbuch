## 5) CV‑Analyse und Vermittler‑Typologie
### 5.a) CV berechnen
kategorien = list(SPRTDICT['sach'].keys()) + list(SPRTDICT['leben'].keys())

def cv(row):
    werte = row[kategorien].values
    werte = werte[werte > 0]
    if len(werte) <= 1:
        return 0
    return np.std(werte) / np.mean(werte)

summary['cv'] = summary.apply(cv, axis=1)

### 5.b) Leben/Sach-Indikatoren
summary['has_leben'] = df['VermittlernummerLeben'].notna()
summary['has_sach']  = df['VermittlernummerSach'].notna()

### 5.c) Optimalen CV‑Cutoff bestimmen (KMeans)
from sklearn.cluster import KMeans

km = KMeans(n_clusters=2, random_state=42).fit(summary[['cv']])
centers = sorted(km.cluster_centers_.flatten())
cv_cutoff = (centers[0] + centers[1]) / 2
cv_cutoff

### 5.d) Typologie bestimmen
def typologie(row):
    if row['has_leben'] and not row['has_sach']:
        return 'leben-fokus'
    if row['has_sach'] and not row['has_leben']:
        return 'sach-fokus'
    if row['has_leben'] and row['has_sach']:
        return 'breit-aktiv' if row['cv'] < cv_cutoff else 'volatil'
    return 'inaktiv'

summary['typ'] = summary.apply(typologie, axis=1)
summary[['cv', 'typ']]

