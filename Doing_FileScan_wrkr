import os
from datetime import datetime
from concurrent.futures import ThreadPoolExecutor, as_completed

# ── Konfiguration (wird vom Notebook überschrieben) ───────────────────────────
SKIP_PREFIX = ('core',)
MAX_THREADS = 16


# ── Hilfsfunktion ─────────────────────────────────────────────────────────────

def _fmt(ts: float) -> str:
    """Formatiert einen Unix-Timestamp als lesbaren String."""
    return datetime.fromtimestamp(ts).strftime('%Y-%m-%d %H:%M')


# ── Kern: ein einzelnes Verzeichnis scannen ───────────────────────────────────

def _scan_single_dir(path: str) -> tuple:
    """
    Scannt ein einzelnes Verzeichnis (nicht rekursiv).
    Symlinks werden grundsätzlich übersprungen — keine Zyklen möglich.
    Gibt zurück: (file_entries, subdir_paths, errors)
    """
    entries = []
    subdirs = []
    errors  = {}

    try:
        with os.scandir(path) as scn:
            for x in scn:

                # Symlinks komplett überspringen — verhindert jede Endlosschleife
                if x.is_symlink():
                    continue

                # Namen-Filter
                if any(x.name.startswith(p) for p in SKIP_PREFIX):
                    continue

                try:
                    if x.is_dir(follow_symlinks=False):
                        subdirs.append(x.path)

                    elif x.is_file(follow_symlinks=False):
                        st = x.stat(follow_symlinks=False)
                        entries.append({
                            'Name':      x.name,
                            'Path':      x.path,
                            'ext':       x.name.rsplit('.', 1)[-1].lower() if '.' in x.name else '',
                            'Type':      st.st_mode,
                            'Inode':     st.st_ino,
                            'IO_Nbr':    st.st_dev,
                            'NbrLinks':  st.st_nlink,
                            'UID':       st.st_uid,
                            'GrID':      st.st_gid,
                            'Size_MB':   round(st.st_size / 1024**2, 4),
                            'MRAcc_Tme': _fmt(st.st_atime),
                            'MRMod_Tme': _fmt(st.st_mtime),
                            'MRCr_Tme':  _fmt(st.st_ctime),
                        })

                except OSError as e:
                    errors[x.path] = str(e)

    except OSError as e:
        errors[path] = str(e)

    return entries, subdirs, errors


# ── Prozess-Funktion: rekursiver Scan eines Root-Verzeichnisses ───────────────

def scan_root(root_path: str) -> tuple:
    """
    Wird als eigener PROZESS ausgeführt.
    Scannt rekursiv ab root_path mit einem internen ThreadPool.
    Gibt zurück: (all_entries, all_errors)
    """
    all_entries = []
    all_errors  = {}
    pending     = [root_path]

    with ThreadPoolExecutor(max_workers=MAX_THREADS) as pool:
        while pending:
            futures = {pool.submit(_scan_single_dir, p): p for p in pending}
            pending = []

            for fut in as_completed(futures):
                try:
                    entries, subdirs, errors = fut.result()
                    all_entries.extend(entries)
                    all_errors.update(errors)
                    pending.extend(subdirs)
                except Exception as e:
                    all_errors[futures[fut]] = str(e)

    return all_entries, all_errors


# ── Root-Verzeichnisse ermitteln ──────────────────────────────────────────────

def get_root_dirs(base: str, skip_prefix: tuple = SKIP_PREFIX) -> list:
    """
    Ermittelt alle direkten Unterverzeichnisse ab 'base'.
    Symlinks und gefilterte Namen werden ausgeschlossen.
    """
    try:
        return [
            e.path for e in os.scandir(base)
            if not e.is_symlink()
            and e.is_dir(follow_symlinks=False)
            and not any(e.name.startswith(p) for p in skip_prefix)
        ]
    except OSError:
        return [base]
