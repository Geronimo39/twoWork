  .page-header h1 { font-size: 18px; color: #5c3eb5; font-weight: 700; }
  .page-header .subtitle { font-size: 11px; color: #666; margin-top: 2px; }
  .badge {
    background: #5c3eb5; color: white;
    font-size: 10px; font-weight: 600;
