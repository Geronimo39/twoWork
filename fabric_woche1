  .card ul { padding-left: 14px; }

  .card-purple { background: #f3f0fd; border-color: #c5b8f5; }
  .card-purple h3 { color: #4a2fa0; }
  .card-teal   { background: #e8f7f2; border-color: #7dd4b8; }
  .card-teal   h3 { color: #0a6e51; }
  .card-coral  { background: #fdf0ec; border-color: #f4b8a0; }
  .card-coral  h3 { color: #8a3318; }
