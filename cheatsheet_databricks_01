stichtag = <span class="fn">dbutils</span>.widgets.get(<span class="str">"run_date"</span>)</pre>

      <h3><span class="label teal">dbutils.notebook</span></h3>
      <pre>result = <span class="fn">dbutils</span>.notebook.run(
    <span class="str">"./silver/as400_bestand"</span>,
    timeout_seconds=<span class="str">600</span>,
    arguments={<span class="str">"run_date"</span>: stichtag})</pre>
