<span class="fn">dbutils</span>.fs.rm(<span class="str">"/mnt/tmp/"</span>, recurse=<span class="kw">True</span>)</pre>

      <h3><span class="label teal">dbutils.secrets</span></h3>
      <pre><span class="cmt"># Kein Klartext-Passwort im Notebook!</span>
pw = <span class="fn">dbutils</span>.secrets.get(
