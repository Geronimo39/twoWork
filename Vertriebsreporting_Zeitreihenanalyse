Die Zielstruktur orientiert sich an Deinem bisherigen Setup:
je Woche ein tabellarischer Bestand mit Vermittlernummer und Produktstückzahlen.
def simulate_segment_data(
    weeks=104,
    start_date="2024-01-01",
    broker_ids=None,
    products=None,
    segment_name="Sach",
    season_strength=0.15,
    trend_strength=0.20,
    event_strength=0.30,
    base_level=20,
    broker_spread=0.45,
    product_weights=None,
    seed=42,
):
    rng = np.random.default_rng(seed)

    if broker_ids is None:
        broker_ids = [f"{segment_name[:2].upper()}{i:05d}" for i in range(1, 81)]
    if products is None:
        products = ["PROD_A", "PROD_B", "PROD_C", "PROD_D"]
    if product_weights is None:
        product_weights = np.ones(len(products)) / len(products)
    else:
        product_weights = np.array(product_weights) / np.sum(product_weights)

    dates = pd.date_range(start=start_date, periods=weeks, freq="W-MON")
    t = np.arange(weeks)

    # allgemeines Markt-/Saison-Signal
    trend = 1 + trend_strength * (t / max(1, weeks - 1))
    season = 1 + season_strength * np.sin(2 * np.pi * t / 52)

    # 2 Sondereffekte für Kampagnen / Aktionen / externe Einflüsse
    events = np.ones(weeks)
    if weeks > 30:
        events[18:24] *= (1 + event_strength * 0.5)
        events[70:76] *= (1 - event_strength * 0.4)

    records = []

    # vermittlerspezifische Produktneigung
    broker_strength = pd.Series(
        rng.lognormal(mean=np.log(base_level), sigma=broker_spread, size=len(broker_ids)),
        index=broker_ids
    )

    broker_activity = pd.Series(
        rng.uniform(0.75, 1.25, size=len(broker_ids)),
        index=broker_ids
    )

    for broker in broker_ids:
        broker_base = broker_strength.loc[broker]
        broker_factor = broker_activity.loc[broker]

        # vermittlerspezifische Schwerpunktverteilung
        broker_mix = rng.dirichlet(alpha=2 + 8 * product_weights)

        for i, dt in enumerate(dates):
            week_scale = trend[i] * season[i] * events[i]
            for p_idx, product in enumerate(products):
                lam = broker_base * broker_factor * broker_mix[p_idx] * week_scale

                # segmenttypische Unterschiede
                if segment_name.lower() == "leben":
                    lam *= 0.65  # typischerweise geringere Stückzahl, dafür wertiger
                else:
                    lam *= 1.00

                # zusätzliche idiosynkratische Streuung
                lam *= rng.uniform(0.85, 1.15)

                value = rng.poisson(max(lam, 0.05))

                records.append({
                    "kw_datum": dt,
                    "jahr": dt.isocalendar().year,
                    "kw": int(dt.isocalendar().week),
                    "segment": segment_name,
                    "vermittler": broker,
                    "produkt": product,
                    "anzahl": int(value),
                })

    return pd.DataFrame(records)

