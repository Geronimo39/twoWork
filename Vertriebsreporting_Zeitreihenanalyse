# Blaupause für reale Datenanbindung (Pseudo-Produktivcode)

from pathlib import Path

def normalize_week_file(df: pd.DataFrame, segment: str, date_col_value) -> pd.DataFrame:
    df = df.copy()
    df["kw_datum"] = pd.to_datetime(date_col_value)
    df["segment"] = segment

    # Beispielhafte Annahme:
    # erste Spalte = Vermittlernummer
    # übrige relevante Produktspalten = SV_* oder LV_*
    id_col = "vermittler"
    if id_col not in df.columns:
        # anpassen, falls die Spalte anders heißt
        raise ValueError("Spalte 'vermittler' nicht gefunden.")

    product_cols = [c for c in df.columns if c.startswith("SV_") or c.startswith("LV_")]
    out = df.melt(
        id_vars=["kw_datum", "segment", id_col],
        value_vars=product_cols,
        var_name="produkt",
        value_name="anzahl"
    ).rename(columns={id_col: "vermittler"})

    out["anzahl"] = pd.to_numeric(out["anzahl"], errors="coerce").fillna(0)
    out["jahr"] = out["kw_datum"].dt.isocalendar().year.astype(int)
    out["kw"] = out["kw_datum"].dt.isocalendar().week.astype(int)
    return out

