## 3) Hilfsfunktionen

Im Notebook werden einige Helfer für Zeitreihenaggregation, Rolling Metriken, Deltas und Forecasts verwendet.
def aggregate_weekly(df_long: pd.DataFrame, by=("segment", "produkt")) -> pd.DataFrame:
    grp_cols = ["kw_datum"] + list(by)
    out = (
        df_long.groupby(grp_cols, as_index=False)["anzahl"]
        .sum()
        .sort_values("kw_datum")
    )
    return out

def add_time_features(df: pd.DataFrame, value_col="anzahl", group_cols=None, windows=(4, 13)):
    if group_cols is None:
        group_cols = []
    df = df.sort_values(group_cols + ["kw_datum"]).copy()

    for w in windows:
        df[f"roll_mean_{w}"] = (
            df.groupby(group_cols, dropna=False)[value_col]
            .transform(lambda s: s.rolling(w, min_periods=1).mean())
        )
        df[f"roll_std_{w}"] = (
            df.groupby(group_cols, dropna=False)[value_col]
            .transform(lambda s: s.rolling(w, min_periods=2).std())
        )
    df["delta_1w"] = df.groupby(group_cols, dropna=False)[value_col].diff(1)
    df["delta_pct_1w"] = df.groupby(group_cols, dropna=False)[value_col].pct_change(1)
    return df

def kpi_table(df_long: pd.DataFrame) -> pd.DataFrame:
    base = (
        df_long.groupby("segment")
        .agg(
            vermittler=("vermittler", "nunique"),
            produkte=("produkt", "nunique"),
            beobachtungen=("anzahl", "size"),
            gesamt_absatz=("anzahl", "sum"),
            mittlere_wochenmenge=("anzahl", "mean"),
            median_wochenmenge=("anzahl", "median"),
        )
        .reset_index()
    )
    return base

def fmt_thousands(x, pos):
    return f"{int(x):,}".replace(",", ".")

def plot_line_with_roll(df, title, y="anzahl", group_col=None, roll_col="roll_mean_13"):
    plt.figure(figsize=(14, 6))
    if group_col is None:
        plt.plot(df["kw_datum"], df[y], label=y)
        if roll_col in df.columns:
            plt.plot(df["kw_datum"], df[roll_col], linewidth=2.5, label=roll_col)
    else:
        for g, sub in df.groupby(group_col):
            plt.plot(sub["kw_datum"], sub[y], label=str(g), alpha=0.6)
            if roll_col in sub.columns:
                plt.plot(sub["kw_datum"], sub[roll_col], linewidth=2.2, label=f"{g} – Trend")
    plt.title(title)
    plt.xlabel("Woche")
    plt.ylabel("Stückzahl")
    plt.gca().yaxis.set_major_formatter(FuncFormatter(fmt_thousands))
    plt.legend()
    plt.tight_layout()
    plt.show()

def build_forecast(series: pd.Series, seasonal_periods=52, horizon=12):
    series = series.asfreq("W-MON")
    model = ExponentialSmoothing(
        series,
        trend="add",
        seasonal="add",
        seasonal_periods=seasonal_periods,
        initialization_method="estimated"
    )
    fit = model.fit(optimized=True)
    fc = fit.forecast(horizon)
    return fit, fc
