def concentration_table(df):
    out = []
    for seg, sub in df.groupby("segment"):
        sub = sub.sort_values("anzahl", ascending=False).reset_index(drop=True)
        total = sub["anzahl"].sum()
        for n in [5, 10, 20]:
            share = sub.head(n)["anzahl"].sum() / total if total else np.nan
            out.append({"segment": seg, "top_n": n, "anteil_absatz": share})
    return pd.DataFrame(out)

