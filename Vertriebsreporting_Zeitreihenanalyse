def build_exec_summary(weekly_total: pd.DataFrame, concentration: pd.DataFrame) -> str:
    out = []
    for seg in ["Sach", "Leben"]:
        sub = weekly_total[weekly_total["segment"] == seg].sort_values("kw_datum")
        latest = sub.iloc[-1]
        first = sub.iloc[0]
        growth_abs = latest["anzahl"] - first["anzahl"]
        growth_pct = growth_abs / first["anzahl"] if first["anzahl"] else np.nan
        avg_vola = sub["roll_std_13"].mean()
        top10 = concentration[(concentration["segment"] == seg) & (concentration["top_n"] == 10)]["anteil_absatz"].iloc[0]

        out.append(
            f"{seg}: Seit Beginn der Beobachtung veränderte sich der Wochenabsatz um "
            f"{growth_abs:,.0f} Stück ({growth_pct:.1%}). "
            f"Die mittlere 13-Wochen-Volatilität liegt bei {avg_vola:,.1f}. "
            f"Die Top-10-Vermittler stehen kumuliert für {top10:.1%} des Absatzes."
        )
    return "\n".join(out)

