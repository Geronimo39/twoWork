# =============================================================================

SQLITE_DB  = Path("as400_analysis.sqlite")
OUTPUT_DIR = Path("output/charts")
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

# Farbpalette (vorstandstauglich)
COLORS = {
    "HIGH":   "#c0392b",
    "MEDIUM": "#e67e22",
    "LOW":    "#3498db",
    "UNUSED": "#95a5a6",
    "HOT":    "#c0392b",
    "COLD":   "#95a5a6",
    "READ":   "#2980b9",
    "WRITE":  "#c0392b",
    "RW":     "#8e44ad",
    "accent": "#2c3e50",
    "bg":     "#f8f9fa",
}

PALETTE = ["#2c3e50","#e74c3c","#3498db","#2ecc71","#f39c12",
           "#9b59b6","#1abc9c","#e67e22","#34495e","#e91e63"]


def save(fig, name: str):
    path = OUTPUT_DIR / f"{name}.png"
    fig.savefig(path, dpi=150, bbox_inches="tight", facecolor="white")
    plt.close(fig)
    log.info(f"  Gespeichert: {path}")
    return path


def load(sql: str, db) -> pd.DataFrame:
    try:
        return pd.read_sql(sql, db)
    except Exception as e:
        log.warning(f"Abfrage fehlgeschlagen: {e}")
        return pd.DataFrame()


