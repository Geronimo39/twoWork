def print_summary_report(conn_sqlite):
    print("\n" + "="*60)
    print("ZUSAMMENFASSUNG")
    print("="*60)

    # Letzte Live-Messung
    df_live = pd.read_sql(
        "SELECT ts, used_mb, total_mb, pct_used FROM storage_history "
        "WHERE source='live' ORDER BY ts DESC LIMIT 1",
        conn_sqlite
    )
    if not df_live.empty:
        r = df_live.iloc[0]
        print(f"  Letzte Disk-Messung: {r.ts}")
        print(f"  Auslastung:          {r.pct_used:.1f}% "
              f"({r.used_mb/1024:.1f} GB von {r.total_mb/1024:.1f} GB)")

    # VRDAT-Stand
    df_vrdat = pd.read_sql(
        "SELECT ts, SUM(row_count) AS total_rows FROM vrdat_row_history "
        "GROUP BY ts ORDER BY ts DESC LIMIT 1",
        conn_sqlite
    )
    if not df_vrdat.empty:
        r = df_vrdat.iloc[0]
        print(f"  Letzter VRDAT-Snapshot: {r.ts}")
        print(f"  Gesamtzeilen VRDAT:     {r.total_rows:,.0f}")

    print()


