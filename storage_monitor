def main():
    print("\n" + "="*60)
    print("  AS/400 Storage Monitor")
    print(f"  {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}")
    print("="*60)

    # SQLite immer öffnen
    conn_sqlite = sqlite3.connect(SQLITE_PATH)
    setup_sqlite(conn_sqlite)

    # --- MODUS 2: Excel-Snapshots (immer ausführen wenn Verzeichnis existiert)
    if os.path.isdir(EXCEL_DIR):
        run_excel_mode(conn_sqlite)
    else:
        print(f"\n[EXCEL] Verzeichnis nicht gefunden: {EXCEL_DIR}")
        print("        EXCEL_DIR in CONFIG anpassen oder Verzeichnis anlegen.")

    # --- MODUS 1: Live-Abfrage (nur wenn AS/400 erreichbar)
    print("\n" + "-"*60)
    live_ok = False
    try:
        conn_as400 = pyodbc.connect(
            f"DSN={ODBC_DSN};", autocommit=True
        )
        conn_as400.setdecoding(pyodbc.SQL_CHAR, encoding="cp273")
        conn_as400.setdecoding(pyodbc.SQL_WCHAR, encoding="utf-16")
        run_live_mode(conn_as400, conn_sqlite)
        conn_as400.close()
        live_ok = True
    except Exception as e:
        print(f"\n[LIVE] AS/400-Verbindung fehlgeschlagen: {e}")
        print("       Excel-Modus wurde trotzdem ausgeführt.")

    # --- Zusammenfassung
    print_summary_report(conn_sqlite)
    conn_sqlite.close()

    if not live_ok:
        print("[HINWEIS] Skript ohne AS/400-Verbindung ausgeführt.")
        print("          Excel-Trendanalyse ist trotzdem vollständig.")

    print("Fertig.\n")


if __name__ == "__main__":
    main()
