"""
AS/400 Spool-File Export → IFS (PDF)
======================================
Liest Spool-Files eines Jobs und kopiert sie via CPYSPLF WSCST(*PDF)
in den IFS. Optionaler zweiter Durchlauf über alle SPLNBR falls die
erste Nummer unbekannt ist.

Verwendung:
  - JOB_ID, SPOOL_FILE_NAME konfigurieren
  - SPLNBR_LIST leer lassen → automatisch alle Nummern probieren
  - SPLNBR_LIST befüllen  → nur diese Nummern holen

Ausgabe:
  - PDF-Dateien im IFS unter IFS_TARGET_DIR
  - Pandas DataFrame mit Ergebnistabelle
  - Optional: Excel-Export

Version: 1.0 | 2026
"""

import pyodbc
import pandas as pd
from datetime import datetime
from pathlib import Path

# ── Konfiguration ─────────────────────────────────────────────────────────────
DSN              = "uvw"              # ODBC-DSN Name
MY_SCHEMA        = "xyz"           
# Job-Identifikation (alle drei Felder für eindeutigen Treffer)
JOB_NUMBER       = "109105"            # Job-Nummer   (z.B. "109105")
JOB_USER         = "EGAL"            # Job-User     (z.B. "jemand")
JOB_NAME         = "TAGEND_NOP"        # Job-Name     (z.B. "TAGEND_NOP")

# Spool-File-Name (so wie er auf der AS/400 heißt, z.B. "QPJOBLOG" oder "QPLOBLOG")
SPOOL_FILE_NAME  = "QPJOBLOG"

# Spool-Nummern:
#   []          → alle Nummern 1..MAX_SPLNBR automatisch durchprobieren
#   [1, 3, 7]   → nur diese drei Nummern holen
SPLNBR_LIST      = []                  # Leer = auto-scan

MAX_SPLNBR       = 20                  # Maximale Spool-Nummer beim Auto-Scan

# IFS-Zielverzeichnis (muss existieren oder wird angelegt)
IFS_TARGET_DIR   = f"/home/{JOB_USER}/spoolfiles"

# Lokaler Ausgabe-Pfad für Excel-Ergebnistabelle (leer = kein Excel)
OUTPUT_EXCEL     = Path(f"spool_export_{JOB_NAME}_{datetime.now().strftime('%Y%m%d_%H%M')}.xlsx")
# ─────────────────────────────────────────────────────────────────────────────


def connect() -> pyodbc.Connection:
    conn = pyodbc.connect(f"DSN={DSN}", autocommit=True)
    conn.setdecoding(pyodbc.SQL_CHAR,  encoding="cp1252")
    conn.setdecoding(pyodbc.SQL_WCHAR, encoding="cp1252")
    conn.setencoding(encoding="cp1252")
    return conn


def run_cl(conn: pyodbc.Connection, cl_command: str) -> tuple[bool, str]:
    """
    Führt ein CL-Kommando via QSYS2.QCMDEXC aus.
    Gibt (True, "") bei Erfolg zurück, (False, Fehlermeldung) bei Fehler.
    """
    escaped = cl_command.replace("'", "''")
    length  = len(cl_command)
    sql     = f"CALL QSYS2.QCMDEXC('{escaped}', {length:.5f})"
    try:
        conn.execute(sql)
        return True, ""
    except Exception as e:
        return False, str(e)


def ensure_ifs_dir(conn: pyodbc.Connection, ifs_dir: str) -> bool:
    """Legt IFS-Verzeichnis an falls es nicht existiert."""
    ok, err = run_cl(conn, f"CRTDIR DIR('{ifs_dir}')")
    if ok:
        print(f"  ✓ IFS-Verzeichnis erstellt: {ifs_dir}")
    else:
        if "bereits vorhanden" in err.lower() or "CPF0011" in err or "already exists" in err.lower():
            print(f"  ✓ IFS-Verzeichnis existiert bereits: {ifs_dir}")
            return True
        print(f"  ✗ IFS-Verzeichnis konnte nicht erstellt werden: {err}")
        return False
    return True


def get_available_splnbr(conn: pyodbc.Connection,
                          job_number: str, job_user: str, job_name: str,
                          spool_file_name: str) -> list[int]:
    """
    Ermittelt verfügbare Spool-Nummern via QSYS2.OUTPUT_QUEUE_ENTRIES.
    Fallback: leere Liste (dann übernimmt der auto-scan).
    """
    print("\n  Suche verfügbare Spool-Nummern via OUTPUT_QUEUE_ENTRIES...")
    sql = f"""
        SELECT
            FILE_NUMBER,
            SPOOLED_FILE_NAME,
            STATUS,
            CREATION_TIMESTAMP,
            PAGES
        FROM QSYS2.OUTPUT_QUEUE_ENTRIES
        WHERE UPPER(JOB_NAME)   = UPPER('{job_name}')
          AND UPPER(JOB_USER)   = UPPER('{job_user}')
          AND UPPER(JOB_NUMBER) = UPPER('{job_number}')
          AND UPPER(SPOOLED_FILE_NAME) = UPPER('{spool_file_name}')
        ORDER BY FILE_NUMBER
    """
    try:
        df = pd.read_sql(sql, conn)
        if not df.empty:
            numbers = df["FILE_NUMBER"].dropna().astype(int).tolist()
            print(f"  ✓ Gefunden: Spool-Nummern {numbers}")
            return numbers
    except Exception as e:
        print(f"  ✗ OUTPUT_QUEUE_ENTRIES: {e}")
    return []


def copy_spool_to_ifs(conn: pyodbc.Connection,
                       job_number: str, job_user: str, job_name: str,
                       spool_file_name: str, splnbr: int,
                       ifs_target_dir: str) -> dict:
    """
    Kopiert einen einzelnen Spool-File als PDF in den IFS.
    Gibt ein Ergebnis-Dict zurück.
    """
    timestamp  = datetime.now().strftime("%Y%m%d_%H%M%S")
    ifs_file   = f"{ifs_target_dir}/{job_name}_{job_number}_splnbr{splnbr:03d}_{timestamp}.pdf"

    # CPYSPLF-Kommando mit WSCST(*PDF)
    cl = (
        f"CPYSPLF"
        f" FILE({spool_file_name})"
        f" TOFILE(*TOSTMF)"
        f" JOB({job_number}/{job_user}/{job_name})"
        f" SPLNBR({splnbr})"
        f" TOSTMF('{ifs_file}')"
        f" STMFOPT(*REPLACE)"
        f" WSCST(*PDF)"
    )

    print(f"\n  SPLNBR {splnbr:>3} → {ifs_file}")
    print(f"    CL: {cl}")

    ok, err = run_cl(conn, cl)

    result = {
        "JOB":          f"{job_number}/{job_user}/{job_name}",
        "SPOOL_FILE":   spool_file_name,
        "SPLNBR":       splnbr,
        "IFS_PFAD":     ifs_file if ok else "",
        "STATUS":       "OK" if ok else "FEHLER",
        "FEHLER_MSG":   "" if ok else err,
        "ZEITSTEMPEL":  timestamp,
    }

    if ok:
        print(f"    ✅ Erfolgreich gespeichert")
    else:
        print(f"    ✗ Fehler: {err}")

    return result


def export_excel(results: list[dict], path: Path):
    """Exportiert die Ergebnistabelle als Excel."""
    df = pd.DataFrame(results)
    with pd.ExcelWriter(path, engine="openpyxl") as writer:
        df.to_excel(writer, sheet_name="Spool_Export", index=False)
        ws = writer.sheets["Spool_Export"]
        for col in ws.columns:
            max_len = max(
                (len(str(cell.value)) for cell in col if cell.value is not None),
                default=10
            )
            ws.column_dimensions[col[0].column_letter].width = min(max_len + 2, 80)
    print(f"\n✅ Excel gespeichert: {path}")


# ── Main ──────────────────────────────────────────────────────────────────────
def main():
    print("=" * 65)
    print("AS/400 Spool-File Export → IFS (PDF via CPYSPLF WSCST(*PDF))")
    print(f"Job:        {JOB_NUMBER}/{JOB_USER}/{JOB_NAME}")
    print(f"Spool-File: {SPOOL_FILE_NAME}")
    print(f"IFS-Ziel:   {IFS_TARGET_DIR}")
    print(f"Zeitstempel: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print("=" * 65)

    conn = connect()

    # ── IFS-Verzeichnis sicherstellen
    print("\n[0] IFS-Verzeichnis prüfen / anlegen...")
    ensure_ifs_dir(conn, IFS_TARGET_DIR)

    # ── Spool-Nummern bestimmen
    if SPLNBR_LIST:
        # Explizit konfiguriert
        splnbr_to_process = SPLNBR_LIST
        print(f"\n[1] Verwende konfigurierte Spool-Nummern: {splnbr_to_process}")
    else:
        # Zuerst über OUTPUT_QUEUE_ENTRIES versuchen
        print(f"\n[1] Spool-Nummern automatisch ermitteln...")
        splnbr_to_process = get_available_splnbr(
            conn, JOB_NUMBER, JOB_USER, JOB_NAME, SPOOL_FILE_NAME
        )

        if not splnbr_to_process:
            # Fallback: Schleife 1..MAX_SPLNBR
            print(f"  → Fallback: Probiere Nummern 1..{MAX_SPLNBR} durch")
            splnbr_to_process = list(range(1, MAX_SPLNBR + 1))

    print(f"\n  Zu verarbeitende SPLNBR: {splnbr_to_process}")

    # ── Spool-Files kopieren
    print(f"\n[2] Starte Spool-File-Export ({len(splnbr_to_process)} Nummern)...")
    results     = []
    ok_count    = 0
    err_count   = 0

    for splnbr in splnbr_to_process:
        result = copy_spool_to_ifs(
            conn,
            JOB_NUMBER, JOB_USER, JOB_NAME,
            SPOOL_FILE_NAME, splnbr,
            IFS_TARGET_DIR
        )
        results.append(result)

        if result["STATUS"] == "OK":
            ok_count += 1
        else:
            err_count += 1

            # Beim Auto-Scan: nach N aufeinanderfolgenden Fehlern abbrechen
            # (Spool-Nummern sind sequenziell — wenn 3 aufeinander fehlen, ist Ende erreicht)
            if not SPLNBR_LIST:
                recent = [r["STATUS"] for r in results[-3:]]
                if len(recent) == 3 and all(s == "FEHLER" for s in recent):
                    print(f"\n  → 3 aufeinanderfolgende Fehler beim Auto-Scan → stoppe")
                    break

    conn.close()

    # ── Zusammenfassung
    print(f"\n{'='*65}")
    print("ERGEBNIS:")
    print(f"  Erfolgreich exportiert: {ok_count} Spool-Files")
    print(f"  Fehler:                 {err_count}")
    print(f"\n  IFS-Pfad: {IFS_TARGET_DIR}")
    print(f"\n  Exportierte Dateien:")
    for r in results:
        if r["STATUS"] == "OK":
            print(f"    ✅ SPLNBR {r['SPLNBR']:>3} → {r['IFS_PFAD']}")
        else:
            print(f"    ✗  SPLNBR {r['SPLNBR']:>3} → {r['FEHLER_MSG'][:60]}")
    print(f"{'='*65}")

    # ── Excel-Export
    if OUTPUT_EXCEL and results:
        export_excel(results, OUTPUT_EXCEL)

    return pd.DataFrame(results)


if __name__ == "__main__":
    df_result = main()
