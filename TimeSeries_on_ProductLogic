def gt_mtrcs(ky=None, dct=SPRTDCT):
    lst = []
    if ky:
        for x in dct[ky].values():
            lst.extend(x)
    else:
        for k in dct.keys():
            for x in dct[k].values():
                lst.extend(x)
    return list(dict.fromkeys(lst))

